# ============================================================
# .env.example — Lịch Vạn Niên AI
# Copy file này thành .env.local và điền giá trị thật
# KHÔNG commit .env vào git
# ============================================================

# ── Groq API (AI chatbot) ─────────────────────────────────────
# Lấy miễn phí tại: https://console.groq.com
# Dùng cho: Hỏi Thầy AI, Tư Vấn AI
PUBLIC_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudflare KV (cache AI responses) ───────────────────────
# Chỉ cần nếu dùng Cloudflare Workers để cache
# Tạo trong: Cloudflare Dashboard → Workers & Pages → KV
# CF_KV_NAMESPACE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CF_KV_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Analytics (optional) ──────────────────────────────
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Site URL (overrideable) ───────────────────────────────────
# Mặc định đã set trong astro.config.mjs
# PUBLIC_SITE_URL=https://lichvannien.io.vn
