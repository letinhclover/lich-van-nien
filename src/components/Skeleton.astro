---
// ============================================================
// src/components/Skeleton.astro — Loading skeleton placeholders
// Dùng khi: fetch AI, load lịch, chờ data từ API
// Nguyên tắc: cùng kích thước với content thật → không layout shift
// ============================================================

interface Props {
  /** Loại skeleton — mỗi loại có shape riêng giống content thật */
  type: 'ai-summary' | 'calendar' | 'hoang-dao' | 'day-card';
  /** Số dòng text (chỉ dùng cho ai-summary) */
  lines?: number;
  /** aria-label cho screen reader */
  label?: string;
}

const {
  type,
  lines = 3,
  label = 'Đang tải...',
} = Astro.props;

// CSS class dùng chung cho từng ô skeleton
// bg-gray-200 light / bg-gray-700 dark — đủ contrast cả 2 mode
const BASE = 'bg-gray-200 dark:bg-gray-700 rounded animate-pulse';
---

<div
  role="status"
  aria-label={label}
  aria-busy="true"
>

  <!-- ── AI Summary Skeleton ─────────────────────────────── -->
  {type === 'ai-summary' && (
    <div class="card p-4 flex flex-col gap-3">
      <!-- Header row: icon + title -->
      <div class="flex items-center gap-2">
        <div class={`${BASE} w-6 h-6 rounded-full shrink-0`}></div>
        <div class={`${BASE} h-4 w-36`}></div>
      </div>
      <!-- Lines: dài ngắn xen kẽ để trông tự nhiên -->
      {Array.from({ length: lines }, (_, i) => (
        <div
          class={`${BASE} h-3`}
          style={`width: ${i % 3 === 0 ? '100%' : i % 3 === 1 ? '83%' : '92%'};`}
        ></div>
      ))}
      <!-- CTA button placeholder -->
      <div class={`${BASE} h-9 w-28 rounded-xl mt-1`}></div>
    </div>
  )}

  <!-- ── Calendar Grid Skeleton ──────────────────────────── -->
  {type === 'calendar' && (
    <div class="card overflow-hidden">
      <!-- Header tháng -->
      <div class="p-3 flex items-center justify-between border-b" style="border-color: var(--border);">
        <div class={`${BASE} h-8 w-20 rounded-lg`}></div>
        <div class={`${BASE} h-6 w-24`}></div>
        <div class={`${BASE} h-8 w-20 rounded-lg`}></div>
      </div>
      <!-- Hàng header thứ: 7 ô CN T2 T3... -->
      <div class="grid grid-cols-7 px-2 pt-2 pb-1 gap-1">
        {Array.from({ length: 7 }, () => (
          <div class={`${BASE} h-4 rounded`}></div>
        ))}
      </div>
      <!-- Grid ngày: 5 tuần × 7 ngày = 35 ô -->
      <div class="grid grid-cols-7 gap-1 p-2">
        {Array.from({ length: 35 }, (_, i) => (
          <div
            class={`${BASE} rounded-lg aspect-square`}
            style={`opacity: ${i < 2 || i > 30 ? 0.3 : 1};`}
          ></div>
        ))}
      </div>
    </div>
  )}

  <!-- ── Giờ Hoàng Đạo Skeleton ──────────────────────────── -->
  {type === 'hoang-dao' && (
    <div class="flex flex-col gap-2">
      <!-- 12 rows giờ -->
      {Array.from({ length: 12 }, (_, i) => (
        <div class="card p-3 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <!-- Icon tròn -->
            <div class={`${BASE} w-8 h-8 rounded-xl shrink-0`}></div>
            <div class="flex flex-col gap-1.5">
              <!-- Tên giờ -->
              <div class={`${BASE} h-3.5`} style={`width: ${60 + (i % 3) * 12}px;`}></div>
              <!-- Can chi -->
              <div class={`${BASE} h-2.5 w-14`}></div>
            </div>
          </div>
          <!-- Badge Hoàng/Hắc đạo -->
          <div class={`${BASE} h-6 w-24 rounded-lg`}></div>
        </div>
      ))}
    </div>
  )}

  <!-- ── Day Card Skeleton ───────────────────────────────── -->
  {type === 'day-card' && (
    <div class="flex flex-col gap-3">
      <!-- Block 1: Hero card — ngày + can chi + score -->
      <div class="card overflow-hidden">
        <div class={`${BASE} h-1.5 w-full rounded-none`}></div>
        <div class="p-4 flex items-start justify-between gap-3">
          <div class="flex flex-col gap-2 flex-1">
            <!-- Thứ + ngày -->
            <div class={`${BASE} h-3 w-20`}></div>
            <!-- Can chi ngày (title lớn) -->
            <div class={`${BASE} h-7 w-48`}></div>
            <!-- Âm lịch -->
            <div class={`${BASE} h-3.5 w-56`}></div>
            <!-- Badges row -->
            <div class="flex gap-1.5 flex-wrap mt-1">
              {Array.from({ length: 4 }, (_, i) => (
                <div class={`${BASE} h-6 rounded-full`} style={`width: ${50 + i * 14}px;`}></div>
              ))}
            </div>
          </div>
          <!-- Score circle -->
          <div class={`${BASE} w-16 h-16 rounded-2xl shrink-0`}></div>
        </div>
      </div>

      <!-- Block 2: Rating table 2×2 -->
      <div class="card overflow-hidden">
        <div class="px-4 py-3 border-b" style="border-color: var(--border);">
          <div class={`${BASE} h-4 w-32`}></div>
        </div>
        <div class="grid grid-cols-2">
          {Array.from({ length: 4 }, (_, i) => (
            <div
              class:list={['p-3 border-b', i % 2 === 0 ? 'border-r' : '']}
              style="border-color: var(--border);"
            >
              <div class={`${BASE} h-3 w-20 mb-2`}></div>
              <div class={`${BASE} h-4 w-24`}></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Screen reader only text -->
  <span class="sr-only">{label}</span>

</div>
