---
// ============================================================
// DayBadge.astro — Thẻ hiển thị thông tin ngày
// Props: solarDate, lunarDate, canChi
// Responsive, dùng được ở nhiều nơi
// ============================================================

export interface Props {
  /** Ngày dương lịch: "13/3/2026" hoặc Date object */
  solarDate: string | Date;
  /** Ngày âm lịch: "14 tháng 2 năm Ất Tỵ" */
  lunarDate: string;
  /** Can Chi ngày: "Bính Tuất" */
  canChi: string;
  /** Nhận xét ngày: "Ngày tốt" | "Ngày trung bình" | "Ngày xấu" */
  rating?: "tot" | "trung" | "xau";
  /** Label nhận xét tùy chỉnh */
  ratingLabel?: string;
  /** Variant hiển thị */
  variant?: "full" | "compact" | "mini";
  /** CSS class thêm vào */
  class?: string;
}

const {
  solarDate,
  lunarDate,
  canChi,
  rating,
  ratingLabel,
  variant = "full",
  class: extraClass = "",
} = Astro.props;

// Format solar date nếu là Date object
const solarStr = solarDate instanceof Date
  ? `${solarDate.getDate()}/${solarDate.getMonth() + 1}/${solarDate.getFullYear()}`
  : solarDate;

// Rating config
const ratingMap = {
  tot:   { label: ratingLabel ?? "Ngày Tốt",        icon: "✅", color: "#16a34a", bg: "rgba(22,163,74,0.1)",    border: "rgba(22,163,74,0.25)"  },
  trung: { label: ratingLabel ?? "Ngày Trung Bình", icon: "⚡", color: "#d97706", bg: "rgba(217,119,6,0.1)",    border: "rgba(217,119,6,0.25)"  },
  xau:   { label: ratingLabel ?? "Ngày Xấu",        icon: "⚠️", color: "#dc2626", bg: "rgba(220,38,38,0.08)",   border: "rgba(220,38,38,0.2)"   },
};
const ratingCfg = rating ? ratingMap[rating] : null;

// Weekday tính từ solarStr "d/m/yyyy"
const weekdays = ["Chủ Nhật","Thứ Hai","Thứ Ba","Thứ Tư","Thứ Năm","Thứ Sáu","Thứ Bảy"];
let weekday = "";
try {
  const parts = solarStr.split("/");
  if (parts.length === 3) {
    const d = new Date(Number(parts[2]), Number(parts[1]) - 1, Number(parts[0]));
    weekday = weekdays[d.getDay()] ?? "";
  }
} catch {}
---

{variant === "full" && (
  <div
    class:list={["day-badge-full", extraClass]}
    style="
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 20px;
      box-shadow: var(--shadow-md);
      position: relative;
      overflow: hidden;
    "
  >
    <!-- Decorative red stripe top -->
    <div style="
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, #C0392B, #E74C3C);
    " />

    <!-- Top row: weekday + rating -->
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
      <span style="
        font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
        text-transform: uppercase; color: var(--text-3);
      ">
        {weekday}
      </span>
      {ratingCfg && (
        <span style={`
          display: inline-flex; align-items: center; gap: 4px;
          font-size: 11px; font-weight: 600;
          padding: 3px 10px; border-radius: 999px;
          color: ${ratingCfg.color};
          background: ${ratingCfg.bg};
          border: 1px solid ${ratingCfg.border};
        `}>
          {ratingCfg.icon} {ratingCfg.label}
        </span>
      )}
    </div>

    <!-- Solar date — big -->
    <div style="
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(40px, 10vw, 64px);
      font-weight: 500;
      line-height: 1;
      color: var(--red, #C0392B);
      margin-bottom: 4px;
      letter-spacing: -1px;
    ">
      {solarStr.split("/")[0]}
      <span style="font-size: 0.45em; color: var(--text-3); font-family: 'Be Vietnam Pro', sans-serif; font-weight: 400; letter-spacing: 0;">
        tháng {solarStr.split("/")[1]}
      </span>
    </div>

    <p style="font-size: 13px; color: var(--text-3); margin-bottom: 14px;">
      {solarStr.split("/")[2]} · Dương Lịch
    </p>

    <!-- Divider -->
    <div style="height: 1px; background: var(--border); margin-bottom: 14px;" />

    <!-- Lunar + Can Chi row -->
    <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;">
      <div>
        <p style="font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-4); margin-bottom: 3px;">
          Âm Lịch
        </p>
        <p style="font-size: 15px; font-weight: 600; color: var(--text-1);">
          🌙 {lunarDate}
        </p>
      </div>
      <div style="text-align: right;">
        <p style="font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-4); margin-bottom: 3px;">
          Can Chi
        </p>
        <p style="
          font-size: 15px; font-weight: 700;
          color: var(--gold, #B8720A);
        ">
          ☯ {canChi}
        </p>
      </div>
    </div>

    <slot />
  </div>
)}

{variant === "compact" && (
  <div
    class:list={["day-badge-compact", extraClass]}
    style="
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 14px;
      box-shadow: var(--shadow-sm);
    "
  >
    <!-- Date circle -->
    <div style="
      width: 52px; height: 52px; flex-shrink: 0;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--red, #C0392B), #E74C3C);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
    ">
      <span style="font-size: 20px; font-weight: 700; color: white; line-height: 1;">
        {solarStr.split("/")[0]}
      </span>
      <span style="font-size: 9px; color: rgba(255,255,255,0.8); font-weight: 500;">
        Tháng {solarStr.split("/")[1]}
      </span>
    </div>

    <!-- Info -->
    <div style="flex: 1; min-width: 0;">
      <p style="font-size: 13px; font-weight: 600; color: var(--text-1); margin-bottom: 2px;">
        {weekday && `${weekday} · `}{solarStr.split("/")[2]}
      </p>
      <p style="font-size: 12px; color: var(--text-3); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
        🌙 {lunarDate}
      </p>
    </div>

    <!-- Can Chi + Rating -->
    <div style="text-align: right; flex-shrink: 0;">
      <p style="font-size: 13px; font-weight: 700; color: var(--gold, #B8720A); margin-bottom: 2px;">
        {canChi}
      </p>
      {ratingCfg && (
        <span style={`
          font-size: 10px; font-weight: 600;
          color: ${ratingCfg.color};
        `}>
          {ratingCfg.icon} {ratingCfg.label}
        </span>
      )}
    </div>
  </div>
)}

{variant === "mini" && (
  <div
    class:list={["day-badge-mini", extraClass]}
    style="
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--red-pale, #FDECEA);
      border: 1px solid rgba(192,57,43,0.2);
      border-radius: 999px;
      padding: 5px 12px 5px 8px;
    "
  >
    <span style="
      width: 24px; height: 24px; border-radius: 50%;
      background: var(--red, #C0392B);
      color: white; font-size: 11px; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    ">
      {solarStr.split("/")[0]}
    </span>
    <span style="font-size: 12px; font-weight: 600; color: var(--red, #C0392B);">
      {canChi}
    </span>
    <span style="font-size: 11px; color: var(--text-3);">
      🌙 {lunarDate}
    </span>
  </div>
)}
