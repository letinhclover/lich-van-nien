---
// ============================================================
// src/components/ErrorState.astro — Error states thân thiện
// Nguyên tắc:
//   - KHÔNG hiện technical error (stack trace, HTTP status...)
//   - LUÔN giải thích được vì sao và người dùng cần làm gì
//   - Tone: bình tĩnh, hướng dẫn, không gây hoảng loạn
// ============================================================

interface Props {
  /** Loại lỗi — quyết định icon, message, action */
  type: 'ai' | 'data' | 'network' | 'notfound';
  /** Hiện nút "Thử lại" nếu true */
  retry?:   boolean;
  /** Override message mặc định (optional) */
  message?: string;
  /** ID của nút retry để JS attach handler */
  retryId?: string;
}

const {
  type,
  retry   = false,
  message,
  retryId = 'btn-retry',
} = Astro.props;

// ── Messages thân thiện — không bao giờ dùng từ kỹ thuật ────
const CONFIG = {
  ai: {
    title:   'AI đang bận xử lý',
    detail:  'Trợ lý AI tạm thời không phản hồi. Thông tin lịch bên dưới vẫn chính xác và đầy đủ.',
    action:  'Thử lại sau ít phút',
    accent:  'var(--gold)',
    paleBg:  'var(--gold-pale)',
    // Clock icon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  data: {
    title:   'Không tải được dữ liệu',
    detail:  'Vui lòng thử lại. Nếu lỗi vẫn tiếp tục, hãy tải lại trang.',
    action:  'Thử lại',
    accent:  'var(--red)',
    paleBg:  'var(--red-pale)',
    // Alert circle icon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  },
  network: {
    title:   'Không có kết nối mạng',
    detail:  'Đang hiển thị dữ liệu đã lưu từ lần trước. Một số tính năng AI sẽ không khả dụng.',
    action:  'Thử kết nối lại',
    accent:  '#6b7280',
    paleBg:  'rgba(107,114,128,0.08)',
    // Wifi-off icon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>`,
  },
  notfound: {
    title:   'Không tìm thấy ngày này',
    detail:  'Ngày bạn tra cứu không có trong hệ thống. Vui lòng chọn ngày khác trong khoảng 2024–2028.',
    action:  'Về trang hôm nay',
    accent:  'var(--red)',
    paleBg:  'var(--red-pale)',
    // Search-x icon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="8" x2="14" y2="14"/><line x1="14" y1="8" x2="8" y2="14"/></svg>`,
  },
} as const;

const cfg = CONFIG[type];
const displayMessage = message ?? cfg.detail;
---

<div
  role="alert"
  aria-live="polite"
  class="card p-5 flex flex-col items-center text-center gap-3"
  style={`border-color: ${cfg.accent}30; background: ${cfg.paleBg};`}
>

  <!-- Icon -->
  <div
    class="w-14 h-14 rounded-2xl flex items-center justify-center shrink-0"
    style={`background: ${cfg.accent}18; color: ${cfg.accent};`}
    aria-hidden="true"
    set:html={cfg.icon}
  ></div>

  <!-- Title -->
  <h3 class="font-bold text-base" style="color: var(--text-1);">
    {cfg.title}
  </h3>

  <!-- Detail message — thân thiện, không technical -->
  <p class="text-sm leading-relaxed max-w-xs" style="color: var(--text-2);">
    {displayMessage}
  </p>

  <!-- Actions -->
  {retry && type !== 'notfound' && (
    <button
      id={retryId}
      type="button"
      class="btn-secondary text-sm mt-1 flex items-center gap-2"
      aria-label={cfg.action}
    >
      <!-- Refresh icon -->
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M23 4v6h-6"/>
        <path d="M1 20v-6h6"/>
        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
      </svg>
      {cfg.action}
    </button>
  )}

  {type === 'notfound' && (
    <a
      href="/"
      class="btn-primary text-sm mt-1 flex items-center gap-2 no-underline"
    >
      <!-- Home icon -->
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      Về trang hôm nay
    </a>
  )}

</div>
