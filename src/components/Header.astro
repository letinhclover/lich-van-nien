---
// src/components/Header.astro
// Sticky header: logo + desktop nav + dark mode toggle

import { SITE } from '../lib/constants';
import { todayVN, formatDayLabel } from '../lib/dateUtils';

const today = todayVN();
const todayLabel = formatDayLabel(today.day, today.month, today.year);
const todayPath  = `/lich/${today.year}/${String(today.month).padStart(2,'0')}/${String(today.day).padStart(2,'0')}`;

const NAV = [
  { href: '/',               label: 'Hôm Nay',    icon: '🗓' },
  { href: '/lich/thang',     label: 'Tháng',       icon: '📅' },
  { href: '/chuyen-doi-lich',label: 'Chuyển Đổi',  icon: '🔄' },
  { href: '/gio-hoang-dao',  label: 'Giờ Hoàng Đạo',icon:'⏰' },
  { href: '/tu-van',         label: 'Tư Vấn AI',   icon: '🤖' },
];

const currentPath = Astro.url.pathname;
---

<!-- ── Desktop Header ───────────────────────────────────── -->
<header
  id="site-header"
  class="sticky top-0 z-50 w-full"
  style="background: var(--nav-bg); border-bottom: 1px solid var(--nav-border); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
>
  <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" aria-label="Trang chủ Lịch Vạn Niên AI" class="flex items-center gap-2.5 shrink-0">
      <div
        class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold text-sm shrink-0"
        style="background: linear-gradient(135deg, var(--red), var(--red-dark)); box-shadow: 0 2px 8px rgba(192,57,43,0.4);"
      >
        🗓
      </div>
      <span class="font-display font-semibold text-base hidden sm:block" style="color: var(--text-1);">
        Lịch Vạn Niên <span style="color: var(--red);">AI</span>
      </span>
    </a>

    <!-- Desktop Nav (md+) -->
    <nav class="hidden md:flex items-center gap-0.5" aria-label="Điều hướng chính">
      {NAV.map(({ href, label, icon }) => {
        const isActive = href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(href);
        return (
          <a
            href={href}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all no-underline',
              isActive
                ? 'text-red font-bold'
                : 'text-[var(--text-3)] hover:text-[var(--text-1)] hover:bg-[var(--bg-surface)]',
            ]}
            style={isActive ? 'color: var(--red); background: var(--red-pale);' : ''}
          >
            <span class="text-sm">{icon}</span>
            <span>{label}</span>
          </a>
        );
      })}
    </nav>

    <!-- Right side: today + dark toggle -->
    <div class="flex items-center gap-2 shrink-0">
      <!-- Ngày hôm nay (desktop) -->
      <a
        href={todayPath}
        class="hidden lg:flex items-center gap-1.5 text-xs font-medium no-underline px-2.5 py-1.5 rounded-lg"
        style="color: var(--text-3); background: var(--bg-surface); border: 1px solid var(--border);"
      >
        📆 {todayLabel}
      </a>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        type="button"
        aria-label="Chuyển đổi giao diện sáng/tối"
        class="w-9 h-9 rounded-xl flex items-center justify-center text-lg touch-target transition-all"
        style="background: var(--bg-surface); border: 1px solid var(--border);"
      >
        <span id="theme-icon">🌙</span>
      </button>
    </div>
  </div>
</header>

<script>
  // Dark mode toggle
  function getTheme(): 'light' | 'dark' {
    try {
      const s = localStorage.getItem('lvn_theme');
      if (s === 'dark' || s === 'light') return s;
    } catch {}
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyTheme(t: 'light' | 'dark') {
    document.documentElement.classList.toggle('dark', t === 'dark');
    const icon = document.getElementById('theme-icon');
    if (icon) icon.textContent = t === 'dark' ? '☀️' : '🌙';
  }

  function toggleTheme() {
    const next: 'light' | 'dark' = getTheme() === 'dark' ? 'light' : 'dark';
    try { localStorage.setItem('lvn_theme', next); } catch {}
    applyTheme(next);
  }

  // Áp dụng ngay
  applyTheme(getTheme());

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
</script>
