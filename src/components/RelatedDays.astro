---
// src/components/RelatedDays.astro
// Hiển thị 7 ngày trong tuần quanh ngày đang xem
// Scroll ngang trên mobile

import { buildSolarDate, solarToPath, THU_SHORT } from '../lib/dateUtils';
import { solarToLunar, getDayQuality } from '../lib/amlich';

interface Props {
  day:   number;
  month: number;
  year:  number;
}

const { day, month, year } = Astro.props;
const solar = buildSolarDate(day, month, year);

// 7 ngày của tuần hiện tại
const weekDays = Array.from({ length: 7 }, (_, i) => {
  const ms  = Date.UTC(year, month - 1, day) + (i - solar.weekday) * 86400000;
  const dt  = new Date(ms);
  const dd  = dt.getUTCDate();
  const mm  = dt.getUTCMonth() + 1;
  const yy  = dt.getUTCFullYear();
  const q   = getDayQuality(dd, mm, yy);
  const lun = solarToLunar(dd, mm, yy);
  const isThis = dd === day && mm === month && yy === year;
  const dotColor = q.score >= 4 ? 'var(--green)' : q.score <= 2 ? 'var(--red)' : 'var(--gold-dark)';

  return { dd, mm, yy, dow: dt.getUTCDay(), isThis, dotColor, lunarDay: lun.day, path: solarToPath(dd, mm, yy) };
});

const thangPath = `/lich/thang/${year}/${String(month).padStart(2,'0')}`;
---

<section aria-label="Ngày trong tuần" class="mb-4">
  <div class="flex items-center justify-between mb-2">
    <h3 class="section-label">📅 Tuần này</h3>
    <a href={thangPath} class="text-xs no-underline" style="color:var(--red);">
      Xem cả tháng {month}/{year} →
    </a>
  </div>

  <!-- Scroll ngang trên mobile -->
  <div class="overflow-x-auto -mx-4 px-4">
    <div class="flex gap-2 min-w-max pb-1">
      {weekDays.map(({ dd, mm, yy, dow, isThis, dotColor, lunarDay, path }) => {
        const isSun = dow === 0;
        const isSat = dow === 6;
        return (
          <a
            href={path}
            aria-current={isThis ? 'date' : undefined}
            class="flex flex-col items-center py-2.5 px-3 rounded-xl no-underline transition-all min-w-[52px]"
            style={isThis
              ? 'background:var(--red);'
              : 'background:var(--bg-card);border:1px solid var(--border);'}
          >
            <!-- Thứ -->
            <span class="text-[9px] font-bold leading-none mb-1"
              style={isThis ? 'color:rgba(255,255,255,0.75);' : 'color:var(--text-3);'}>
              {THU_SHORT[dow]}
            </span>
            <!-- Dot tốt/xấu -->
            <span class="w-1.5 h-1.5 rounded-full mb-1"
              style={`background:${isThis ? 'rgba(255,255,255,0.6)' : dotColor};`}></span>
            <!-- Ngày dương -->
            <span class="font-bold text-base leading-none"
              style={isThis
                ? 'color:white;'
                : isSun ? 'color:var(--red);'
                : isSat ? 'color:var(--gold-dark);'
                : 'color:var(--text-1);'}>
              {dd}
            </span>
            <!-- Ngày âm -->
            <span class="text-[9px] mt-0.5 leading-none"
              style={isThis ? 'color:rgba(255,255,255,0.7);' : 'color:var(--text-4);'}>
              {lunarDay === 1 ? `M.${solarToLunar(dd, mm, yy).month}` : lunarDay}
            </span>
            <!-- Tháng khác -->
            {mm !== month && (
              <span class="text-[8px] mt-0.5" style="color:var(--text-4);">/{mm}</span>
            )}
          </a>
        );
      })}
    </div>
  </div>
</section>
