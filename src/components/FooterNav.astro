---
// src/components/FooterNav.astro
// Mobile: compact 2 dòng links — không lãng phí diện tích
// Desktop: 3 cột đầy đủ

import { todayVN } from '../lib/dateUtils';
import { SITE } from '../lib/constants';

const today = todayVN();
const curY  = today.year;
const nextY = curY + 1;

const FEATURES = [
  { href:'/',                label:'Hôm nay'       },
  { href:'/gio-hoang-dao',   label:'Hoàng đạo'     },
  { href:'/chuyen-doi-lich', label:'Đổi lịch'      },
  { href:'/chon-ngay-cuoi',  label:'Ngày cưới'     },
  { href:'/tu-van',          label:'Tư vấn AI'     },
  { href:'/van-trinh',       label:'Vận trình'     },
  { href:'/tiet-khi',        label:'Tiết khí'      },
  { href:'/can-chi',         label:'Can chi'       },
  { href:'/developer',       label:'API'           },
  { href:'/xem-tuoi-hop',    label:'Tuổi vợ chồng' },
  { href:'/ban-menh',        label:'Bản mệnh'      },
  { href:'/xem-tuoi-hop',    label:'Tuổi vợ chồng' },
  { href:'/gioi-thieu',      label:'Giới thiệu'    },
  { href:'/chinh-sach',      label:'Chính sách'    },
];
---

<!-- Mobile: compact | Desktop: full 3-column -->
<footer class="border-t mt-6" style="border-color:var(--border);">

  <!-- MOBILE: 2 dòng gọn -->
  <div class="md:hidden px-4 py-3 pb-20">
    <!-- Dòng 1: tháng nhanh -->
    <div class="overflow-x-auto -mx-4 px-4 mb-2">
      <div class="flex gap-1 min-w-max">
        {Array.from({length:12},(_,i)=>i+1).map(m => (
          <a
            href={`/lich/thang/${curY}/${String(m).padStart(2,'0')}`}
            class="text-xs px-2.5 py-1 rounded-full no-underline whitespace-nowrap"
            style={m === today.month
              ? 'background:var(--red);color:white;font-weight:700;'
              : 'background:var(--bg-surface);color:var(--text-3);border:1px solid var(--border);'}
          >
            T.{m}
          </a>
        ))}
      </div>
    </div>

    <!-- Dòng 2: tính năng -->
    <div class="overflow-x-auto -mx-4 px-4">
      <div class="flex gap-2 min-w-max">
        {FEATURES.map(({ href, label }) => (
          <a
            href={href}
            class="text-xs no-underline whitespace-nowrap py-0.5"
            style="color:var(--text-4);"
          >
            {label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- DESKTOP: 3 cột đầy đủ -->
  <div class="hidden md:block max-w-2xl mx-auto px-4 py-6 pb-8">
    <div class="grid grid-cols-3 gap-6">
      <div>
        <p class="section-label mb-3">📅 Lịch {curY}</p>
        <div class="grid grid-cols-4 gap-1">
          {Array.from({length:12},(_,i)=>i+1).map(m => (
            <a href={`/lich/thang/${curY}/${String(m).padStart(2,'0')}`}
              class="text-xs py-1 px-1.5 rounded-lg no-underline text-center"
              style={m === today.month ? 'color:var(--red);font-weight:700;' : 'color:var(--text-3);'}>
              T.{m}
            </a>
          ))}
        </div>
      </div>
      <div>
        <p class="section-label mb-3">🔧 Tính năng</p>
        <div class="flex flex-col gap-1.5">
          {FEATURES.map(({ href, label }) => (
            <a href={href} class="text-xs no-underline" style="color:var(--text-3);">{label}</a>
          ))}
        </div>
      </div>
      <div>
        <p class="section-label mb-3">📅 Lịch {nextY}</p>
        <div class="grid grid-cols-4 gap-1">
          {Array.from({length:12},(_,i)=>i+1).map(m => (
            <a href={`/lich/thang/${nextY}/${String(m).padStart(2,'0')}`}
              class="text-xs py-1 px-1.5 rounded-lg no-underline text-center"
              style="color:var(--text-3);">
              T.{m}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

</footer>
