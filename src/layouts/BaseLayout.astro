---
// BaseLayout.astro — Layout đầy đủ cho các trang SEO tĩnh
// Dùng cho: /lich/yyyy/mm/dd và các trang SEO khác
// Có: header, bottom nav, dark mode, CSS tokens

import { SITE_CONFIG } from '../lib/config';
import '../index.css';

interface Props {
  title?:        string;
  description?:  string;
  ogImage?:      string;
  canonicalUrl?: string;
  schema?:       object;
}

const {
  title       = SITE_CONFIG.siteNameFull,
  description = SITE_CONFIG.description,
  ogImage     = SITE_CONFIG.defaultOgImage,
  canonicalUrl = Astro.url.href,
  schema,
} = Astro.props;

const today = new Date();
const thu = ["Chủ Nhật","Thứ Hai","Thứ Ba","Thứ Tư","Thứ Năm","Thứ Sáu","Thứ Bảy"];
const todayStr = `${thu[today.getDay()]}, ${today.getDate()}/${today.getMonth()+1}/${today.getFullYear()}`;
---
<!DOCTYPE html>
<html lang="vi" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#C0392B" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#1a0a08" media="(prefers-color-scheme: dark)" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- PWA -->
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index, follow" />
  <meta name="google-site-verification" content="Ayd10DMuvfW7FDDg0_ugpWAsIXbryRv7wyxDWH5vkjc" />

  <!-- Open Graph -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:type"        content="website" />
  <meta property="og:locale"      content="vi_VN" />
  <meta property="og:site_name"   content={SITE_CONFIG.siteName} />

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- JSON-LD schema (nếu có) -->
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <!-- Dark mode no-flash -->
  <script is:inline>
    (function(){
      try{
        var t=localStorage.getItem('lvn_theme');
        if(t==='dark') document.documentElement.classList.add('dark');
      }catch(e){}
    })();
  </script>
</head>
<body style="background:var(--bg);color:var(--text-1);">

  <!-- Desktop Header -->
  <header class="hidden md:flex items-center justify-between px-6 h-14 sticky top-0 z-40 border-b"
    style="background:var(--nav-bg);border-color:var(--nav-border);backdrop-filter:blur(12px);">
    <a href="/" class="flex items-center gap-2.5 no-underline" aria-label="Trang chủ">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center text-base font-bold text-white"
        style="background:linear-gradient(135deg,var(--red),var(--red-dark));">🗓</div>
      <span class="font-display font-medium text-base" style="color:var(--text-1);">
        Lịch Vạn Niên <span style="color:var(--red);">AI</span>
      </span>
    </a>
    <nav class="flex items-center gap-1">
      {[
        { href:"/",           label:"Hôm Nay"  },
        { href:"/thang",      label:"Tháng"    },
        { href:"/chuyen-doi", label:"Chuyển Đổi"},
        { href:"/ai",         label:"AI"        },
      ].map(({href,label}) => (
        <a href={href}
          class="px-3 py-1.5 rounded-lg text-sm font-medium transition-all no-underline"
          style="color:var(--text-3);">{label}</a>
      ))}
    </nav>
    <span class="text-xs font-medium" style="color:var(--text-3);">📆 {todayStr}</span>
  </header>

  <!-- Mobile Header -->
  <header class="flex md:hidden items-center justify-between px-4 h-12 sticky top-0 z-40"
    style="background:var(--nav-bg);border-bottom:1px solid var(--nav-border);backdrop-filter:blur(12px);">
    <a href="/" class="flex items-center gap-2 no-underline">
      <span class="text-lg">🗓</span>
      <span class="font-display text-sm font-medium" style="color:var(--text-1);">
        Lịch Vạn Niên <span style="color:var(--red);">AI</span>
      </span>
    </a>
    <button id="theme-toggle-mobile" aria-label="Đổi giao diện"
      class="w-8 h-8 rounded-full flex items-center justify-center"
      style="background:var(--bg-surface);border:1px solid var(--border);">
      <span id="theme-icon-mobile">🌙</span>
    </button>
  </header>

  <!-- Main Content -->
  <main id="main-content" class="w-full max-w-2xl mx-auto px-4"
    style="padding-bottom:calc(80px + env(safe-area-inset-bottom,0px));min-height:calc(100svh - 48px);">
    <slot />
  </main>

  <!-- Bottom Nav (mobile) -->
  <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex items-stretch"
    style="background:var(--nav-bg);border-top:1px solid var(--nav-border);backdrop-filter:blur(16px);padding-bottom:env(safe-area-inset-bottom,0px);min-height:56px;">
    {[
      { href:"/",           label:"Hôm Nay", icon:"🗓" },
      { href:"/thang",      label:"Tháng",   icon:"📅" },
      { href:"/chuyen-doi", label:"Đổi Lịch",icon:"🔄" },
      { href:"/ai",         label:"AI",      icon:"🤖" },
      { href:"/cai-dat",    label:"Cài Đặt", icon:"⚙️" },
    ].map(({href,label,icon}) => (
      <a href={href}
        class="flex-1 flex flex-col items-center justify-center gap-0.5 no-underline"
        style="min-height:56px;color:var(--text-3);"
        aria-label={label}>
        <span style="font-size:1.3rem;line-height:1;">{icon}</span>
        <span style="font-size:10px;font-weight:600;line-height:1;">{label}</span>
      </a>
    ))}
  </nav>

  <script>
    // Dark mode toggle
    function getTheme(){ try{ return localStorage.getItem('lvn_theme')||'light'; }catch{ return 'light'; } }
    function applyTheme(t: string){
      document.documentElement.classList.toggle('dark', t==='dark');
      const icon = t==='dark'?'☀️':'🌙';
      const el = document.getElementById('theme-icon-mobile');
      if(el) el.textContent = icon;
    }
    applyTheme(getTheme());
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', ()=>{
      const next = getTheme()==='dark'?'light':'dark';
      try{ localStorage.setItem('lvn_theme',next); }catch{}
      applyTheme(next);
    });
  </script>
</body>
</html>
