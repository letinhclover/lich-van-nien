---
// ============================================================
// src/layouts/BaseLayout.astro — Layout chính Lịch Vạn Niên AI
// ============================================================
// PROPS:
//   title           — <title> + og:title (max 60 ký tự)
//   description     — meta description + og:description (max 160)
//   ogImage         — og:image URL (1200×630)
//   canonicalUrl    — canonical + og:url
//   pageDate        — lastmod cho structured data (ISO string)
//   googleVerification — meta google-site-verification
//   jsonLd / schema — JSON-LD object hoặc array (alias nhau)
//   noindex         — noindex,nofollow nếu true
// ============================================================

import { SITE } from '../lib/constants';
import { todayVN } from '../lib/dateUtils';
import FooterNav from '../components/FooterNav.astro';
import '../styles/global.css';

interface Props {
  title?:               string;
  description?:         string;
  ogImage?:             string;
  canonicalUrl?:        string;
  pageDate?:            string;
  googleVerification?:  string;
  /** JSON-LD schema — tên chính thức theo task */
  jsonLd?:              object | object[];
  /** Alias để tương thích với pages hiện tại (dùng schema=...) */
  schema?:              object | object[];
  noindex?:             boolean;
  /** rel=prev URL cho SEO pagination */
  prevUrl?:             string;
  /** rel=next URL cho SEO pagination */
  nextUrl?:             string;
}

const {
  title             = SITE.siteNameFull,
  description       = SITE.description,
  ogImage           = SITE.ogImage,
  canonicalUrl      = Astro.url.href,
  pageDate,
  googleVerification = 'Ayd10DMuvfW7FDDg0_ugpWAsIXbryRv7wyxDWH5vkjc',
  jsonLd,
  schema,
  noindex           = false,
  prevUrl,
  nextUrl,
} = Astro.props;

// jsonLd và schema là alias — ưu tiên jsonLd
const structuredData = jsonLd ?? schema;

// Giới hạn SEO
const safeTitle = title.slice(0, 60);
const safeDesc  = description.slice(0, 160);

// Ngày hôm nay để build bottom nav "Tháng"
const today      = todayVN();
const thangPath  = `/lich/thang/${today.year}/${String(today.month).padStart(2,'0')}`;
const currentPath = Astro.url.pathname;

// Bottom nav tabs
const TABS = [
  {
    href: '/',
    label: 'Hôm Nay',
    // Calendar icon
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><rect x="8" y="14" width="3" height="3" rx="0.5" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    href: thangPath,
    label: 'Tháng',
    // Grid calendar icon
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="9" y1="14" x2="9" y2="14"/><line x1="12" y1="14" x2="12" y2="14"/><line x1="15" y1="14" x2="15" y2="14"/><line x1="9" y1="18" x2="9" y2="18"/><line x1="12" y1="18" x2="12" y2="18"/><line x1="15" y1="18" x2="15" y2="18"/></svg>`,
  },
  {
    href: '/chuyen-doi-lich',
    label: 'Đổi Lịch',
    // Arrows swap icon
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16V4m0 0L3 8m4-4 4 4"/><path d="M17 8v12m0 0 4-4m-4 4-4-4"/></svg>`,
  },
  {
    href: '/tu-van',
    label: 'AI',
    // Sparkle/AI icon
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>`,
  },
  {
    href: '/cai-dat',
    label: 'Cài Đặt',
    // Settings gear icon
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
  },
] as const;

// Desktop nav items
const DESKTOP_NAV = [
  { href: '/',               label: 'Hôm Nay'   },
  { href: thangPath,         label: 'Tháng'      },
  { href: '/chuyen-doi-lich',label: 'Đổi Lịch'  },
  { href: '/gio-hoang-dao',  label: 'Hoàng Đạo' },
  { href: '/tu-van',         label: 'Tư Vấn AI' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  // Tab Tháng: active cho cả /lich/thang/...
  if (href.startsWith('/lich/thang')) return currentPath.startsWith('/lich/thang');
  return currentPath.startsWith(href);
}
---

<!DOCTYPE html>
<html lang="vi" class="scroll-smooth">
<head>
  <!--
    ⚠️ QUAN TRỌNG: Script chống dark mode flash phải là
    THẺ ĐẦU TIÊN TRONG HEAD, trước mọi CSS/link/meta khác.
    Bất kỳ CSS nào load trước = flash trắng rồi tối.
  -->
  <script is:inline>
    (function(){
      try{
        var t=localStorage.getItem('theme')||(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');
        document.documentElement.classList.toggle('dark',t==='dark');
      }catch(e){}
    })();
  </script>

  <!-- Charset & Viewport -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

  <!-- Theme color -->
  <meta name="theme-color" content="#C0392B" />
  <meta name="theme-color" content="#C0392B" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#110805" media="(prefers-color-scheme: dark)" />

  <!-- Favicons & PWA icons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="apple-touch-icon" sizes="152x152" href="/apple-touch-icon-152.png" />
  <link rel="apple-touch-icon" sizes="167x167" href="/apple-touch-icon-167.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180.png" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Lịch VN AI" />

  <!-- SEO -->
  <title>{safeTitle}</title>
  <meta name="description" content={safeDesc} />
  <link rel="canonical" href={canonicalUrl} />
  {prevUrl && <link rel="prev" href={prevUrl} />}
  {nextUrl && <link rel="next" href={nextUrl} />}
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
  <meta name="author" content={SITE.siteName} />
  {pageDate && <meta name="revised" content={pageDate} />}

  <!-- Google Verification -->
  {googleVerification && (
    <meta name="google-site-verification" content={googleVerification} />
  )}

  <!-- Open Graph -->
  <meta property="og:type"         content="website" />
  <meta property="og:site_name"    content={SITE.siteName} />
  <meta property="og:url"          content={canonicalUrl} />
  <meta property="og:title"        content={safeTitle} />
  <meta property="og:description"  content={safeDesc} />
  <meta property="og:image"        content={ogImage} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale"       content="vi_VN" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={safeTitle} />
  <meta name="twitter:description" content={safeDesc} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Preconnect fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Be Vietnam Pro 400,500,600,700,800 + Playfair Display -->
  <link
    href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Playfair+Display:wght@400;600;700;900&display=swap"
    rel="stylesheet"
  />

  <!-- Global CSS (Tailwind) -->
  <style>
    /* Inline critical: ngăn flash background trước khi CSS load */
    html { background: #FFFDF9; }
    html.dark { background: #110805; }
  </style>

  <!-- JSON-LD Structured Data -->
  {structuredData && (
    Array.isArray(structuredData)
      ? structuredData.map(s => <script type="application/ld+json" set:html={JSON.stringify(s)} />)
      : <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  )}
</head>

<body class="min-h-screen" style="background: var(--bg); color: var(--text-1);">

  <!-- ── DESKTOP HEADER (hidden on mobile) ─────────────────── -->
  <header
    class="hidden md:flex items-center justify-between sticky top-0 z-50 px-6 h-14 border-b"
    style="background: var(--nav-bg); border-color: var(--nav-border); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);"
  >
    <!-- Logo -->
    <a href="/" aria-label="Trang chủ Lịch Vạn Niên AI" class="flex items-center gap-2.5 no-underline shrink-0">
      <div
        class="w-8 h-8 rounded-lg flex items-center justify-center text-white text-sm font-bold"
        style="background: linear-gradient(135deg, var(--red), var(--red-dark)); box-shadow: 0 2px 8px rgba(192,57,43,0.4);"
      >
        🗓
      </div>
      <span class="font-display font-semibold text-base" style="color: var(--text-1);">
        Lịch Vạn Niên <span style="color: var(--red);">AI</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="flex items-center gap-0.5" aria-label="Điều hướng chính">
      {DESKTOP_NAV.map(({ href, label }) => {
        const active = isActive(href);
        return (
          <a
            href={href}
            aria-current={active ? 'page' : undefined}
            class="px-3 py-1.5 rounded-lg text-sm font-medium transition-all no-underline"
            style={active
              ? 'color: var(--red); background: var(--red-pale); font-weight: 700;'
              : 'color: var(--text-3);'}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <!-- Dark mode toggle -->
    <button
      id="theme-toggle"
      type="button"
      aria-label="Chuyển đổi giao diện sáng/tối"
      class="w-9 h-9 rounded-xl flex items-center justify-center text-lg transition-all"
      style="background: var(--bg-surface); border: 1px solid var(--border);"
    >
      <span id="theme-icon">🌙</span>
    </button>
  </header>

  <!-- ── MAIN CONTENT ───────────────────────────────────────── -->
  <main
    id="main-content"
    class="w-full max-w-2xl mx-auto px-4 py-4 pb-20 md:pb-4 min-h-screen"
  >
    <slot />
  </main>

  <FooterNav />

  <!-- ── BOTTOM NAVIGATION (mobile only) ───────────────────── -->
  <nav
    class="md:hidden fixed bottom-0 left-0 right-0 z-50"
    aria-label="Điều hướng chính"
    style="
      background: var(--nav-bg);
      border-top: 1px solid var(--nav-border);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      height: calc(64px + env(safe-area-inset-bottom, 0px));
      padding-bottom: env(safe-area-inset-bottom, 0px);
    "
  >
    <div class="flex items-stretch h-16">
      {TABS.map(({ href, label, svg }) => {
        const active = isActive(href);
        return (
          <a
            href={href}
            aria-label={label}
            aria-current={active ? 'page' : undefined}
            class:list={[
              'flex-1 flex flex-col items-center justify-center gap-0.5 no-underline relative',
              active ? 'border-t-2 border-do-500 text-do-500' : 'text-gray-400 dark:text-gray-500',
            ]}
          >
            <!-- SVG icon -->
            <span
              class="leading-none"
              aria-hidden="true"
              set:html={svg}
            />
            <!-- Label -->
            <span
              class:list={[
                'text-[9px] leading-none',
                active ? 'font-bold text-do-500' : 'font-medium',
              ]}
            >
              {label}
            </span>
          </a>
        );
      })}
    </div>
  </nav>

  <!-- ── DARK MODE TOGGLE SCRIPT ────────────────────────────── -->
  <script is:inline>
    // Sync icon với theme hiện tại
    function syncIcon(){
      var isDark = document.documentElement.classList.contains('dark');
      var icon = document.getElementById('theme-icon');
      if(icon) icon.textContent = isDark ? '☀️' : '🌙';
    }

    // Toggle dark mode
    function toggleDark(){
      var d = document.documentElement.classList.toggle('dark');
      try { localStorage.setItem('theme', d ? 'dark' : 'light'); } catch(e){}
      syncIcon();
    }

    // Sync icon ngay khi DOM ready
    syncIcon();
    document.getElementById('theme-toggle')?.addEventListener('click', toggleDark);
  </script>

</body>
</html>
