---
// ============================================================
// BaseLayout.astro — Lịch Vạn Niên AI
// Mobile-first · Đỏ truyền thống · Dark mode class-based
// ============================================================

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title       = "Lịch Vạn Niên AI 2026 — Xem Ngày Tốt Xấu, Âm Lịch, Phong Thủy",
  description = "Lịch vạn niên, âm lịch 2026, xem ngày tốt xấu, phong thủy, tử vi, văn khấn, AI luận giải. Ứng dụng miễn phí cho người Việt.",
  ogImage     = "/og-image.png",
  canonicalUrl = Astro.url.href,
} = Astro.props;

// Ngày hôm nay cho header desktop
const today = new Date();
const weekdays = ["Chủ Nhật","Thứ Hai","Thứ Ba","Thứ Tư","Thứ Năm","Thứ Sáu","Thứ Bảy"];
const todayStr = `${weekdays[today.getDay()]}, ${today.getDate()}/${today.getMonth()+1}/${today.getFullYear()}`;
---

<!DOCTYPE html>
<html lang="vi" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#C0392B" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#1a0a08" media="(prefers-color-scheme: dark)" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="vi_VN" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- PWA / App -->
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <!-- Fonts: preconnect + load -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- CSS Variables + Base Styles -->
  <style is:global>
    :root {
      /* Brand */
      --red:        #C0392B;
      --red-dark:   #96281B;
      --red-light:  #E74C3C;
      --red-pale:   #FDECEA;
      --gold:       #B8720A;
      --gold-light: #F5A623;

      /* Light mode */
      --bg:         #FFFDF9;
      --bg-surface: #F7F2EA;
      --bg-card:    #FFFFFF;
      --border:     #E8DDD0;
      --text-1:     #1A0E08;
      --text-2:     #4A3728;
      --text-3:     #8B6B55;
      --text-4:     #B89880;

      /* Shadows */
      --shadow-sm:  0 1px 3px rgba(26,14,8,0.08);
      --shadow-md:  0 4px 16px rgba(26,14,8,0.10);
      --shadow-lg:  0 8px 32px rgba(26,14,8,0.14);

      /* Nav */
      --nav-bg:     rgba(255, 253, 249, 0.92);
      --nav-border: rgba(192, 57, 43, 0.12);
    }

    .dark {
      --bg:         #120806;
      --bg-surface: #1E0F0A;
      --bg-card:    #251208;
      --border:     #3D1F14;
      --text-1:     #F5EDE5;
      --text-2:     #C9A98E;
      --text-3:     #8B6B55;
      --text-4:     #5A3D2B;

      --red-pale:   rgba(192,57,43,0.15);
      --gold:       #F5A623;

      --shadow-sm:  0 1px 3px rgba(0,0,0,0.3);
      --shadow-md:  0 4px 16px rgba(0,0,0,0.4);
      --shadow-lg:  0 8px 32px rgba(0,0,0,0.5);

      --nav-bg:     rgba(18, 8, 6, 0.95);
      --nav-border: rgba(192, 57, 43, 0.25);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      background: var(--bg);
      color: var(--text-1);
      font-family: "Be Vietnam Pro", system-ui, sans-serif;
      font-size: 16px;
      line-height: 1.6;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      min-height: 100svh;
      background: var(--bg);
      transition: background 0.2s, color 0.2s;
    }

    /* Red accent scrollbar */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--bg-surface); }
    ::-webkit-scrollbar-thumb { background: var(--red); border-radius: 2px; }

    /* Focus ring */
    :focus-visible { outline: 2px solid var(--red); outline-offset: 3px; border-radius: 4px; }

    /* Utility classes */
    .font-display { font-family: "Playfair Display", Georgia, serif; }
    .text-red  { color: var(--red); }
    .text-gold { color: var(--gold); }
    .bg-card   { background: var(--bg-card); }
    .border-soft { border: 1px solid var(--border); }
  </style>
</head>

<body>

  <!-- ─── Desktop Header (hidden on mobile) ─────────────────── -->
  <header class="
    hidden md:flex items-center justify-between
    px-6 h-14 sticky top-0 z-40
    border-b
  " style="
    background: var(--nav-bg);
    border-color: var(--nav-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: var(--shadow-sm);
  ">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 no-underline group" aria-label="Trang chủ Lịch Vạn Niên AI">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center text-base font-bold text-white flex-shrink-0"
        style="background: linear-gradient(135deg, var(--red), var(--red-dark)); box-shadow: 0 2px 8px rgba(192,57,43,0.4);">
        🗓
      </div>
      <span class="font-display font-medium text-base tracking-tight" style="color: var(--text-1);">
        Lịch Vạn Niên <span style="color: var(--red);">AI</span>
      </span>
    </a>

    <!-- Desktop Navigation links -->
    <nav class="flex items-center gap-1" aria-label="Menu chính">
      {[
        { href: "/",         label: "Hôm Nay",    icon: "🗓"  },
        { href: "/thang",    label: "Tháng",       icon: "📅"  },
        { href: "/chuyen-doi", label: "Chuyển Đổi", icon: "🔄"  },
        { href: "/ai",       label: "AI",           icon: "🤖"  },
        { href: "/cai-dat",  label: "Cài Đặt",     icon: "⚙️"  },
      ].map(({ href, label, icon }) => (
        <a
          href={href}
          class="nav-link flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all no-underline"
          style="color: var(--text-3);"
        >
          <span class="text-sm">{icon}</span>
          <span>{label}</span>
        </a>
      ))}
    </nav>

    <!-- Right: Today + Dark mode toggle -->
    <div class="flex items-center gap-3">
      <!-- Ngày hôm nay -->
      <span class="text-xs font-medium" style="color: var(--text-3);">
        📆 {todayStr}
      </span>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        aria-label="Chuyển đổi giao diện sáng/tối"
        class="w-8 h-8 rounded-lg flex items-center justify-center text-base transition-all"
        style="background: var(--bg-surface); border: 1px solid var(--border);"
      >
        <span id="theme-icon">🌙</span>
      </button>
    </div>
  </header>

  <!-- ─── Mobile Header (shown on mobile only) ─────────────── -->
  <header class="
    flex md:hidden items-center justify-between
    px-4 h-12 sticky top-0 z-40
  " style="
    background: var(--nav-bg);
    border-bottom: 1px solid var(--nav-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  ">
    <a href="/" class="flex items-center gap-2 no-underline" aria-label="Trang chủ">
      <span class="text-lg">🗓</span>
      <span class="font-display text-sm font-medium" style="color: var(--text-1);">
        Lịch Vạn Niên <span style="color: var(--red);">AI</span>
      </span>
    </a>

    <button
      id="theme-toggle-mobile"
      aria-label="Chuyển đổi giao diện"
      class="w-8 h-8 rounded-full flex items-center justify-center text-base"
      style="background: var(--bg-surface); border: 1px solid var(--border);"
    >
      <span id="theme-icon-mobile">🌙</span>
    </button>
  </header>

  <!-- ─── Main Content ──────────────────────────────────────── -->
  <main
    id="main-content"
    class="w-full max-w-2xl mx-auto"
    style="
      padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px));
      min-height: calc(100svh - 48px);
    "
  >
    <slot />
  </main>

  <!-- ─── Bottom Navigation (mobile only) ──────────────────── -->
  <nav
    id="bottom-nav"
    aria-label="Điều hướng chính"
    class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex items-stretch"
    style="
      background: var(--nav-bg);
      border-top: 1px solid var(--nav-border);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
      padding-bottom: env(safe-area-inset-bottom, 0px);
      min-height: 56px;
    "
  >
    {[
      { href: "/",           label: "Hôm Nay",    icon: "🗓",  key: "today"    },
      { href: "/thang",      label: "Tháng",       icon: "📅",  key: "month"    },
      { href: "/chuyen-doi", label: "Đổi Lịch",   icon: "🔄",  key: "convert"  },
      { href: "/ai",         label: "AI",           icon: "🤖",  key: "ai"       },
      { href: "/cai-dat",    label: "Cài Đặt",     icon: "⚙️",  key: "settings" },
    ].map(({ href, label, icon, key }) => (
      <a
        href={href}
        data-nav-key={key}
        class="bottom-nav-item flex-1 flex flex-col items-center justify-center gap-0.5 no-underline transition-all"
        style="
          min-height: 56px;
          color: var(--text-3);
          position: relative;
        "
        aria-label={label}
      >
        <span class="text-xl leading-none">{icon}</span>
        <span class="text-[10px] font-medium leading-none">{label}</span>
        <!-- Active indicator dot -->
        <span
          class="bottom-nav-dot absolute top-0 left-1/2 -translate-x-1/2 w-6 h-0.5 rounded-full opacity-0 transition-opacity"
          style="background: var(--red);"
        />
      </a>
    ))}
  </nav>

  <!-- ─── Scripts ───────────────────────────────────────────── -->
  <script>
    // ── Dark mode ──────────────────────────────────────────────
    function getTheme(): "light" | "dark" {
      try {
        const saved = localStorage.getItem("lvn_theme");
        if (saved === "dark" || saved === "light") return saved;
      } catch {}
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }

    function applyTheme(theme: "light" | "dark") {
      const html = document.documentElement;
      if (theme === "dark") {
        html.classList.add("dark");
      } else {
        html.classList.remove("dark");
      }
      const icon = theme === "dark" ? "☀️" : "🌙";
      const iconEl  = document.getElementById("theme-icon");
      const iconElM = document.getElementById("theme-icon-mobile");
      if (iconEl)  iconEl.textContent  = icon;
      if (iconElM) iconElM.textContent = icon;
    }

    function toggleTheme() {
      const current = document.documentElement.classList.contains("dark") ? "dark" : "light";
      const next = current === "dark" ? "light" : "dark";
      try { localStorage.setItem("lvn_theme", next); } catch {}
      applyTheme(next);
    }

    // Apply on load (before paint to avoid flash)
    applyTheme(getTheme());

    document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
    document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);

    // ── Bottom nav active state ────────────────────────────────
    const path = window.location.pathname;
    const keyMap: Record<string, string> = {
      "/":           "today",
      "/thang":      "month",
      "/chuyen-doi": "convert",
      "/ai":         "ai",
      "/cai-dat":    "settings",
    };
    const activeKey = keyMap[path] ?? "today";

    document.querySelectorAll<HTMLElement>(".bottom-nav-item").forEach((el) => {
      const key = el.dataset.navKey;
      if (key === activeKey) {
        el.style.color = "var(--red)";
        const dot = el.querySelector<HTMLElement>(".bottom-nav-dot");
        if (dot) dot.style.opacity = "1";
        el.setAttribute("aria-current", "page");
      }
    });

    // ── Desktop nav active state ───────────────────────────────
    document.querySelectorAll<HTMLAnchorElement>(".nav-link").forEach((el) => {
      if (el.getAttribute("href") === path) {
        el.style.color     = "var(--red)";
        el.style.background = "var(--red-pale)";
        el.style.fontWeight = "600";
      } else {
        el.addEventListener("mouseenter", () => {
          el.style.color     = "var(--text-1)";
          el.style.background = "var(--bg-surface)";
        });
        el.addEventListener("mouseleave", () => {
          el.style.color     = "var(--text-3)";
          el.style.background = "transparent";
        });
      }
    });
  </script>

</body>
</html>
