---
// src/layouts/BaseLayout.astro
// Layout chính bao bọc tất cả trang
// Bao gồm: BaseHead, Header, BottomNav, main content slot

import BaseHead      from '../components/BaseHead.astro';
import Header        from '../components/Header.astro';
import BottomNav     from '../components/BottomNav.astro';
import '../styles/global.css';
import { SITE }      from '../lib/constants';
import type { SeoMeta } from '../lib/types';

interface Props extends Partial<SeoMeta> {
  /** JSON-LD schema object(s) */
  schema?: object | object[];
  /** Chiều rộng max của main content */
  maxWidth?: 'sm' | 'md' | 'lg' | 'full';
  /** Tắt padding bottom nav (cho trang có bottom nav riêng) */
  noNavPad?: boolean;
}

const {
  title       = SITE.siteNameFull,
  description = SITE.description,
  canonical   = Astro.url.href,
  ogImage     = SITE.ogImage,
  noindex     = false,
  schema,
  maxWidth    = 'md',
  noNavPad    = false,
} = Astro.props;

const maxWClasses: Record<string, string> = {
  sm:   'max-w-lg',
  md:   'max-w-2xl',
  lg:   'max-w-5xl',
  full: 'max-w-none',
};
const mwClass = maxWClasses[maxWidth] ?? 'max-w-2xl';
---

<!DOCTYPE html>
<html lang="vi" class="scroll-smooth">
<head>
  <BaseHead
    title={title}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    noindex={noindex}
    schema={schema}
  />
</head>
<body>
  <Header />

  <main
    id="main-content"
    class:list={['w-full mx-auto px-4 py-4', mwClass, noNavPad ? 'pb-4' : 'pb-nav']}
  >
    <slot />
  </main>

  <BottomNav />
</body>
</html>
