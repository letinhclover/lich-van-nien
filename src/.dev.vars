# ============================================================
# .dev.vars — Biến môi trường cho local development
#
# ⚠️  FILE NÀY ĐÃ CÓ TRONG .gitignore — KHÔNG BAO GIỜ COMMIT
# ⚠️  KHÔNG share file này cho bất kỳ ai
# ⚠️  KHÔNG paste nội dung vào chat, email, Slack, v.v.
#
# Cách dùng:
#   1. Sao chép file này: cp .dev.vars.example .dev.vars
#   2. Điền API key thật vào
#   3. Chạy: wrangler pages dev dist --env .dev.vars
#
# Production secrets được set qua:
#   wrangler secret put GROQ_API_KEY
#   (KHÔNG phải qua file này)
# ============================================================

# Anthropic API key — lấy tại https://console.anthropic.com
# Format: gsk_api03-...
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Override môi trường cho local dev
ENVIRONMENT=development

# Base URL cho local (không đổi)
BASE_URL=http://localhost:4321
