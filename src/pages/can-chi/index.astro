---
// src/pages/can-chi/index.astro — Grid 60 can chi
import BaseLayout  from '../../layouts/BaseLayout.astro';
import Breadcrumb  from '../../components/Breadcrumb.astro';
import { SITE }    from '../../lib/constants';
import CAN_CHI_PROFILES from '../../lib/can-chi-profiles';

const canonical  = `${SITE.baseUrl}/can-chi`;
const title      = '60 Hoa Giáp Can Chi — Ý nghĩa ngày lịch âm Việt Nam | Lịch Vạn Niên'.slice(0,60);
const description = 'Tra cứu 60 can chi lịch âm: Giáp Tý, Ất Sửu... đến Quý Hợi. Ý nghĩa, tính cách, màu sắc hợp mệnh và phong thuỷ từng ngày can chi.';

const NH_LABEL: Record<string,string> = {
  'Mộc':'🌿','Hỏa':'🔥','Thổ':'🌏','Kim':'🪙','Thủy':'💧',
};

// Group by ngũ hành
const byNH: Record<string, typeof CAN_CHI_PROFILES> = {
  'Mộc':[],'Hỏa':[],'Thổ':[],'Kim':[],'Thủy':[],
};
CAN_CHI_PROFILES.forEach(p => {
  byNH[p.nguHanh]?.push(p);
});
---

<BaseLayout {title} {description} canonicalUrl={canonical}>

  <Breadcrumb items={[
    { label: 'Trang chủ', href: '/' },
    { label: '60 Can Chi' },
  ]} />

  <h1 class="font-display font-bold text-2xl mb-1" style="color:var(--text-1);">
    🔮 60 Hoa Giáp Can Chi
  </h1>
  <p class="text-sm mb-5" style="color:var(--text-2);">
    Tra cứu ý nghĩa, tính cách và phong thuỷ 60 ngày can chi lịch âm Việt Nam.
  </p>

  {Object.entries(byNH).map(([nguHanh, profiles]) => profiles.length > 0 && (
    <section class="mb-5">
      <h2 class="section-label mb-3">
        {NH_LABEL[nguHanh]} {nguHanh} ({profiles.length} can chi)
      </h2>
      <div class="grid grid-cols-3 gap-2">
        {profiles.map(p => (
          <a
            href={`/can-chi/${p.slug}`}
            class="card p-2.5 no-underline hover:shadow-md transition-shadow text-center"
          >
            <p class="font-bold text-sm leading-none mb-1" style={`color:${p.color};`}>{p.name}</p>
            <p class="text-[10px]" style="color:var(--text-4);">Con {p.conGiap}</p>
          </a>
        ))}
      </div>
    </section>
  ))}

</BaseLayout>
