---
// src/pages/tu-vi/index.astro — Grid 60 tử vi tuổi
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { SITE }   from '../../lib/constants';
import { getCanChiYear } from '../../lib/amlich';
import CAN_CHI_PROFILES from '../../lib/can-chi-profiles';

const canChi2027 = getCanChiYear(2027); // Đinh Mùi
const canonical  = `${SITE.baseUrl}/tu-vi`;
const title      = `Tử vi năm 2027 theo tuổi — 60 tuổi âm lịch đầy đủ | Lịch Vạn Niên`.slice(0,60);
const description = `Tử vi năm 2027 ${canChi2027} cho 60 tuổi âm lịch: Giáp Tý, Ất Sửu... đến Quý Hợi. Tài lộc, sự nghiệp, tình duyên, sức khỏe và tháng tốt.`;

const byNH: Record<string, typeof CAN_CHI_PROFILES> = {
  'Mộc':[],'Hỏa':[],'Thổ':[],'Kim':[],'Thủy':[],
};
CAN_CHI_PROFILES.forEach(p => byNH[p.nguHanh]?.push(p));
---

<BaseLayout {title} {description} canonicalUrl={canonical}>

  <Breadcrumb items={[
    { label: 'Trang chủ', href: '/' },
    { label: 'Tử vi 2027' },
  ]} />

  <h1 class="font-display font-bold text-2xl mb-1" style="color:var(--text-1);">
    🔮 Tử vi năm 2027 theo tuổi
  </h1>
  <p class="text-sm mb-5" style="color:var(--text-2);">
    Vận trình năm 2027 ({canChi2027}) cho 60 tuổi âm lịch — tài lộc, sự nghiệp, tình duyên đầy đủ.
  </p>

  {Object.entries(byNH).map(([nh, profiles]) => profiles.length > 0 && (
    <section class="mb-5">
      <h2 class="section-label mb-3">
        {nh === 'Mộc' ? '🌿' : nh === 'Hỏa' ? '🔥' : nh === 'Thổ' ? '🌏' : nh === 'Kim' ? '🪙' : '💧'}
        {' '}Mệnh {nh}
      </h2>
      <div class="grid grid-cols-3 gap-2">
        {profiles.map(p => (
          <a href={`/tu-vi/${p.slug}`}
            class="card p-2.5 no-underline hover:shadow-md transition-shadow text-center">
            <p class="font-bold text-sm leading-none mb-1" style={`color:${p.color};`}>{p.name}</p>
            <p class="text-[10px]" style="color:var(--text-4);">Con {p.conGiap}</p>
          </a>
        ))}
      </div>
    </section>
  ))}

</BaseLayout>
