---
// src/pages/404.astro — Trang lỗi 404

import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/constants';
import { todayVN, solarToPath } from '../lib/dateUtils';

const { day, month, year } = todayVN();
const todayPath = solarToPath(day, month, year);
---

<BaseLayout
  title="Trang không tồn tại — Lịch Vạn Niên AI"
  description="Trang bạn tìm không tồn tại."
  canonical={SITE.baseUrl + '/404'}
  noindex={true}
>
  <div class="text-center py-16">
    <div class="text-6xl mb-4">🗓️</div>
    <h1 class="font-display font-bold text-3xl mb-2" style="color: var(--text-1);">404</h1>
    <p class="text-lg mb-1" style="color: var(--text-2);">Trang không tìm thấy</p>
    <p class="text-sm mb-8" style="color: var(--text-3);">
      Trang bạn đang tìm không tồn tại hoặc đã được chuyển.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/" class="btn-primary">🏠 Về trang chủ</a>
      <a href={todayPath} class="btn-secondary">📅 Lịch hôm nay</a>
    </div>
  </div>
</BaseLayout>
