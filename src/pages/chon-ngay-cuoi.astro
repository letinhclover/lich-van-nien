---
// src/pages/chon-ngay-cuoi.astro
import BaseLayout        from '../layouts/BaseLayout.astro';
import WeddingDatePicker from '../components/WeddingDatePicker';
import { SITE } from '../lib/constants';
import Breadcrumb from '../components/Breadcrumb.astro';

const title       = 'Chọn ngày cưới 2026 theo lịch âm — Tư vấn ngày đẹp miễn phí | Lịch Vạn Niên'.slice(0,60);
const description = 'Tìm ngày cưới đẹp năm 2026 theo âm lịch. Lọc tự động ngày tốt, tránh Tam Nương, Nguyệt Kỵ. Chọn tháng và xem danh sách ngày cưới đẹp miễn phí.'.slice(0,160);
const canonical   = `${SITE.baseUrl}/chon-ngay-cuoi`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type':    'FAQPage',
  mainEntity: [
    {
      '@type':'Question',
      name:'Ngày nào tốt để cưới năm 2026?',
      acceptedAnswer:{
        '@type':'Answer',
        text:'Ngày tốt để cưới cần có điểm tốt từ 4-5 sao, không rơi vào ngày Tam Nương (3,7,13,18,22,27 âm lịch) và ngày Nguyệt Kỵ (5,14,23 âm lịch). Dùng công cụ bên trên để tìm danh sách ngày đẹp theo tháng bạn muốn.',
      },
    },
    {
      '@type':'Question',
      name:'Ngày Tam Nương là những ngày nào?',
      acceptedAnswer:{
        '@type':'Answer',
        text:'Ngày Tam Nương theo âm lịch là các ngày 3, 7, 13, 18, 22, 27 hàng tháng. Đây là những ngày được coi là không tốt để tổ chức đám cưới và các sự kiện quan trọng trong phong tục Việt Nam.',
      },
    },
    {
      '@type':'Question',
      name:'Có cần xem tuổi khi chọn ngày cưới không?',
      acceptedAnswer:{
        '@type':'Answer',
        text:'Theo phong tục truyền thống, nên tham khảo xem tuổi vợ chồng có hợp nhau không và có rơi vào tuổi hạn lớn không. Tuy nhiên đây chỉ là tham khảo theo quan niệm dân gian.',
      },
    },
  ],
};
---
<BaseLayout {title} {description} canonicalUrl={canonical} {jsonLd}>

  <Breadcrumb items={[
    { label: 'Trang chủ', href: '/' },
    { label: 'Chọn Ngày Cưới' },
  ]} />

  <h1 class="font-display font-bold text-2xl mb-2" style="color:var(--text-1);">
    💍 Công cụ chọn ngày cưới đẹp 2026
  </h1>
  <p class="text-sm mb-5 leading-relaxed" style="color:var(--text-2);">
    Tìm ngày cưới đẹp theo âm lịch Việt Nam. Tự động lọc ngày tốt (score ≥ 4), loại bỏ
    ngày Tam Nương và Nguyệt Kỵ. Chọn tháng và năm để xem danh sách đề xuất.
  </p>

  <WeddingDatePicker client:load />

  <!-- FAQ -->
  <div class="card p-4 mt-5 mb-2">
    <h2 class="font-bold text-sm mb-3" style="color:var(--text-1);">❓ Câu hỏi thường gặp</h2>
    <div class="flex flex-col gap-3">
      <div>
        <p class="font-semibold text-sm" style="color:var(--text-1);">Ngày Tam Nương là những ngày nào?</p>
        <p class="text-sm mt-1" style="color:var(--text-2);">
          Ngày 3, 7, 13, 18, 22, 27 âm lịch hàng tháng — theo phong tục cần tránh cho việc cưới hỏi.
        </p>
      </div>
      <div class="divider"></div>
      <div>
        <p class="font-semibold text-sm" style="color:var(--text-1);">Ngày Nguyệt Kỵ là gì?</p>
        <p class="text-sm mt-1" style="color:var(--text-2);">
          Ngày 5, 14, 23 âm lịch hàng tháng — ngày không thuận lợi theo lịch pháp cổ.
        </p>
      </div>
    </div>
  </div>

</BaseLayout>
