---
// src/pages/index.astro — Trang chủ
// Render toàn bộ React SPA (App.tsx) như một Astro island
// Astro cung cấp: HTML shell + SEO meta tags (SSG)
// React xử lý: toàn bộ UI interactive (CSR)

import SpaLayout from '../layouts/SpaLayout.astro';
import App from '../App';
import '../index.css';
---

<SpaLayout
  title="Lịch Vạn Niên AI 2026 — Lịch Âm, Xem Ngày Tốt Xấu, Phong Thủy"
  description="Lịch vạn niên 2026, lịch âm, xem ngày tốt xấu, 114 sao cát hung, 12 trực, hỏi thầy AI, la bàn phong thủy Bát Trạch, văn khấn 25 bài, xem tuổi hợp — miễn phí, chính xác."
>
  <!-- React SPA hydrate ngay khi load -->
  <App client:load />
</SpaLayout>
