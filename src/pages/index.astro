---
// ============================================================
// src/pages/index.astro — Trang chủ Lịch Vạn Niên AI
// Dữ liệu tính tại BUILD TIME (Astro SSG — không cần JS để render)
// ============================================================

import BaseLayout       from '../layouts/BaseLayout.astro';
import { getVietnamNow, buildSolarDate, solarToPath,
         prevDayPath, nextDayPath, formatDateVN, THU_SHORT } from '../lib/dateUtils';
import { solarToLunar, getCanChi, getDayQuality, getHoangDao } from '../lib/amlich';
import { SITE }         from '../lib/constants';
import AISummary        from '../components/AISummary';
import SaoTrucBadge     from '../components/SaoTrucBadge.astro';

// ─── Dữ liệu hôm nay (build-time, UTC+7) ─────────────────────
const now    = getVietnamNow();
const { day: d, month: m, year: y, hour: currentHour } = now;

const solar   = buildSolarDate(d, m, y);
const lunar   = solarToLunar(d, m, y);
const canChi  = getCanChi(d, m, y);
const quality = getDayQuality(d, m, y);
const hours   = getHoangDao(d, m, y);

// Paths điều hướng
const todayPath    = solarToPath(d, m, y);
const prevPath     = prevDayPath(d, m, y);
const nextPath     = nextDayPath(d, m, y);
const thangPath    = `/lich/thang/${y}/${String(m).padStart(2,'0')}`;

// Giờ đang diễn ra: giờ Tý bắt đầu từ 23h
const todayDateStr = `${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
const currentGioIdx = ((currentHour + 1) % 24) < 2
  ? 0
  : Math.floor(((currentHour + 1) % 24) / 2);

// Lunar display
const lunarLabel = `${lunar.leap ? 'Nhuận ' : ''}${lunar.day} tháng ${lunar.month} năm ${lunar.yearName}`;

// Score hiển thị
const scoreDots = Array.from({ length: 5 }, (_, i) => i < quality.score);
const scoreLabel = quality.score >= 4 ? 'NGÀY TỐT' : quality.score === 3 ? 'BÌNH THƯỜNG' : 'NGÀY XẤU';
const ramMungBadge: string | null = lunar.day === 15 ? '🌕 Ngày Rằm' : lunar.day === 1 ? '🌑 Mùng Một' : null;
const scoreBadgeStyle = quality.score >= 4
  ? 'background:var(--green-pale);color:var(--green);border:1px solid rgba(29,158,117,0.3);'
  : quality.score === 3
    ? 'background:var(--gold-pale);color:var(--gold-dark);border:1px solid rgba(241,196,15,0.3);'
    : 'background:var(--red-pale);color:var(--red);border:1px solid var(--border-red);';

// Lịch tuần: 7 ngày từ CN đến T7 của tuần hiện tại
const weekDays = Array.from({ length: 7 }, (_, i) => {
  const ms = Date.UTC(y, m - 1, d) + (i - solar.weekday) * 86400000;
  const dt = new Date(ms);
  return {
    dd: dt.getUTCDate(),
    mm: dt.getUTCMonth() + 1,
    yy: dt.getUTCFullYear(),
    dow: dt.getUTCDay(),
    isToday: dt.getUTCDate() === d && dt.getUTCMonth() + 1 === m,
  };
});

// ─── SEO ──────────────────────────────────────────────────────
const title       = `Lịch âm hôm nay ${d}/${m}/${y} — ${scoreLabel} | Lịch Vạn Niên AI`;
const description = `Lịch âm hôm nay ${solar.weekdayLabel} ${d}/${m}/${y}: ngày ${lunarLabel}. Can chi ${canChi.ngay.display}. ${quality.label}. Xem giờ hoàng đạo, tứ trụ, ngày tốt xấu đầy đủ.`.slice(0, 160);
const canonical   = SITE.baseUrl + '/';

// ─── FAQPage JSON-LD ──────────────────────────────────────────
const todayJDN = (() => {
  let yy = y, mm = m;
  if (mm <= 2) { yy--; mm += 12; }
  const A = Math.floor(yy / 100);
  const B = 2 - A + Math.floor(A / 4);
  return Math.floor(365.25 * (yy + 4716)) + Math.floor(30.6001 * (mm + 1)) + d + B - 1524;
})();

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type':    'WebSite',
    name:       SITE.siteNameFull,
    url:        SITE.baseUrl,
    potentialAction: {
      '@type':       'SearchAction',
      target:        `${SITE.baseUrl}/lich/{year}/{month}/{day}`,
      'query-input': 'required name=year,month,day',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type':    'FAQPage',
    mainEntity: [
      {
        '@type':  'Question',
        name:     `Hôm nay ${d}/${m}/${y} âm lịch là ngày mấy?`,
        acceptedAnswer: {
          '@type': 'Answer',
          text:    `Hôm nay ${d}/${m}/${y} (${solar.weekdayLabel}) âm lịch là ngày ${lunarLabel}. Can chi ngày: ${canChi.ngay.display}.`,
        },
      },
      {
        '@type':  'Question',
        name:     `Ngày ${d}/${m}/${y} có tốt không?`,
        acceptedAnswer: {
          '@type': 'Answer',
          text:    `Ngày ${d}/${m}/${y}: ${quality.label} (${quality.score}/5 điểm). ${quality.goodFor.length > 0 ? 'Nên làm: ' + quality.goodFor.slice(0,3).join(', ') + '.' : ''}`,
        },
      },
      {
        '@type':  'Question',
        name:     `Giờ hoàng đạo hôm nay ${d}/${m}/${y}?`,
        acceptedAnswer: {
          '@type': 'Answer',
          text:    `Giờ hoàng đạo hôm nay: ${hours.filter(h => h.isHoangDao).map(h => h.tenGio).join(', ')}.`,
        },
      },
    ],
  },
];
---

<BaseLayout
  {title}
  {description}
  canonicalUrl={canonical}
  {jsonLd}
  googleVerification="Ayd10DMuvfW7FDDg0_ugpWAsIXbryRv7wyxDWH5vkjc"
>
<script is:inline define:vars={{ todayJDN }}>
  document.body.dataset.jdn = todayJDN;
</script>

<!-- ── HERO: Big date card ───────────────────────────────────── -->
<section aria-label="Lịch âm hôm nay" class="mb-3">
  <div class="card">
    <!-- Header strip -->
    <div class="flex items-center justify-between px-4 py-3 border-b" style="border-color:var(--border);">
      <div>
        <p class="font-bold text-base" style="color:var(--text-1);">{solar.weekdayLabel}</p>
        <p class="text-sm" style="color:var(--text-3);">Tháng {m} · {y}</p>
      </div>
      <div class="text-right">
        <p class="section-label">Âm Lịch</p>
        <p class="font-bold text-lg" style="color:var(--gold-dark);">{lunar.day}/{lunar.month}</p>
      </div>
    </div>

    <!-- Big date -->
    <div class="flex flex-col items-center py-5 px-4">
      <span class="day-number">{String(d).padStart(2,'00')}</span>

      <!-- Score bar -->
      <div class="flex gap-1 mt-2 mb-3">
        {scoreDots.map(filled => (
          <div class="h-1.5 w-8 rounded-full"
            style={`background:${filled ? quality.color : 'var(--border)'};`}></div>
        ))}
      </div>

      <!-- Status badge -->
      {(() => {
        const badgeStyle = quality.score >= 4
          ? 'background:var(--green-pale);color:var(--green);'
          : quality.score <= 2
            ? 'background:var(--red-pale);color:var(--red);'
            : 'background:var(--gold-pale);color:var(--gold-dark);';
        const badgeText = quality.score >= 4 ? 'Ngày Tốt'
          : quality.score <= 2 ? 'Ngày Xấu' : 'Bình Thường';
        const extra = [
          quality.isTamNuong ? 'Tam Nương' : '',
          quality.isNguyetKy  ? 'Nguyệt Kỵ' : '',
          ramMungBadge ?? '',
        ].filter(Boolean).join(' · ');
        return (
          <span class="px-4 py-1.5 rounded-full text-sm font-bold mb-4" style={badgeStyle}>
            {badgeText}{extra ? ` · ${extra}` : ''}
          </span>
        );
      })()}

      <!-- 3-col can chi strip -->
      <div class="flex w-full rounded-2xl overflow-hidden" style="background:var(--bg-surface);">
        {([
          { label:'NGÀY',  val: canChi.ngay.display,  sub: canChi.ngay.nguHanh },
          { label:'THÁNG', val: canChi.thang.display, sub: canChi.thang.nguHanh },
          { label:'NĂM',   val: canChi.nam.display,   sub: canChi.nam.nguHanh },
        ] as const).map(({ label, val, sub }) => (
          <div class="canchhi-col">
            <p class="section-label mb-1">{label}</p>
            <p class="font-display font-bold text-base leading-tight text-center" style="color:var(--gold-dark);">{val}</p>
            <p class="text-xs mt-0.5" style="color:var(--text-4);">{sub}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Nav: prev | hôm nay | next -->
    <div class="flex border-t" style="border-color:var(--border);">
      <a href={prevPath} class="flex-1 flex items-center justify-center py-3 text-sm font-medium"
        style="color:var(--text-2);border-right:1px solid var(--border);">‹ Hôm qua</a>
      <a href="/" class="flex-1 flex items-center justify-center py-3 text-sm font-bold"
        style="color:var(--gold);border-right:1px solid var(--border);">Hôm nay</a>
      <a href={nextPath} class="flex-1 flex items-center justify-center py-3 text-sm font-medium"
        style="color:var(--text-2);">Ngày sau ›</a>
    </div>
  </div>
</section>

<!-- ── WEEK STRIP ─────────────────────────────────────────────── -->
<section class="mb-3">
  <div class="card p-3">
    <div class="grid grid-cols-7 gap-1">
      {weekDays.map(({ dd, mm, yy, dow, isToday }) => (
        <a href={solarToPath(dd, mm, yy)}
          class="flex flex-col items-center py-2 rounded-xl no-underline"
          aria-current={isToday ? 'date' : undefined}
          style={isToday ? 'background:var(--red);' : ''}>
          <span class="text-[9px] font-bold"
            style={isToday ? 'color:rgba(255,255,255,0.75);' : 'color:var(--text-4);'}>
            {THU_SHORT[dow]}
          </span>
          <span class="font-bold text-base leading-snug"
            style={isToday ? 'color:white;' : dow===0 ? 'color:var(--red);' : dow===6 ? 'color:var(--gold-dark);' : 'color:var(--text-1);'}>
            {dd}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ── AI SUMMARY ────────────────────────────────────────────── -->
<div id="ai-summary" class="card p-3 mb-3" style="min-height:64px;" aria-label="Luận giải AI">
  <div class="flex gap-2 animate-pulse">
    <div class="skeleton w-5 h-5 rounded-full shrink-0 mt-0.5"></div>
    <div class="flex-1 flex flex-col gap-1.5">
      <div class="skeleton h-2.5 rounded w-full"></div>
      <div class="skeleton h-2.5 rounded w-3/4"></div>
    </div>
  </div>
</div>

<!-- ── GIỜ HOÀNG ĐẠO — COMPACT ──────────────────────────────── -->
<section class="mb-3">
  <div class="flex items-center justify-between mb-2">
    <p class="section-label">⏰ Giờ Hoàng Đạo Hôm Nay</p>
    <a href="/gio-hoang-dao" class="text-xs font-medium" style="color:var(--gold);">Xem đủ 12 giờ →</a>
  </div>
  <div class="card p-3">
    <div class="flex flex-wrap gap-2 mb-2">
      {hours.filter(h => h.isHoangDao).map((h) => {
        const isCurrent = hours.indexOf(h) === currentGioIdx;
        return (
          <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-sm font-semibold"
            style={isCurrent
              ? 'background:var(--red);color:white;'
              : 'background:var(--green-pale);color:var(--green);'}>
            {h.tenGio.replace('Giờ ','')}
            {isCurrent && <span class="text-xs opacity-75">← Hiện tại</span>}
          </span>
        );
      })}
    </div>
    <p class="text-sm" style="color:var(--text-3);" id="hoang-dao-list" data-gio-idx={currentGioIdx}>
      Đang là <strong style="color:var(--text-1);">{hours[currentGioIdx]?.tenGio ?? '...'}</strong> —
      <span style={`color:${hours[currentGioIdx]?.isHoangDao?'var(--green)':'var(--text-3)'};font-weight:600;`}>
        {hours[currentGioIdx]?.isHoangDao ? '✓ Hoàng Đạo' : 'Hắc Đạo'}
      </span>
    </p>
  </div>
</section>

<!-- ── TỨ TRỤ đầy đủ (GIỜ) ──────────────────────────────────── -->
<section class="mb-3">
  <p class="section-label mb-2">🔮 Tứ Trụ Ngày Hôm Nay</p>
  <div class="card">
    <div class="grid grid-cols-2">
      {([
        { label:'NĂM',   cc: canChi.nam,   },
        { label:'THÁNG', cc: canChi.thang  },
        { label:'NGÀY',  cc: canChi.ngay   },
        { label:'GIỜ',   cc: canChi.gio, realtime:true },
      ] as const).map(({ label, cc, realtime }, i) => (
        <div class="p-4" style={`${i<2?'border-bottom:1px solid var(--border);':''}${i%2===0?'border-right:1px solid var(--border);':''}`}>
          <p class="section-label mb-1">{label}</p>
          <p class="font-display font-bold text-lg leading-tight" style="color:var(--text-1);"
            id={realtime?'gio-canchichi':undefined}>{cc.display}</p>
          <p class="text-xs mt-0.5" style="color:var(--text-3);">{cc.nguHanh}</p>
          {realtime && <p class="text-[10px] mt-0.5" style="color:var(--text-4);" id="gio-label">Đang cập nhật...</p>}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── NÊN LÀM / TRÁNH ───────────────────────────────────────── -->
{(quality.goodFor.length > 0 || quality.badFor.length > 0) && (
<section class="mb-3">
  <p class="section-label mb-2">📋 Hôm Nay Nên Làm Gì?</p>
  <div class="card p-4">
    {quality.goodFor.length > 0 && (
      <div class="mb-3">
        <p class="section-label mb-2">✅ Nên làm</p>
        <div class="flex flex-wrap gap-1.5">
          {quality.goodFor.map(g => <span class="badge-green">{g}</span>)}
        </div>
      </div>
    )}
    {quality.badFor.length > 0 && (
      <div>
        <p class="section-label mb-2">❌ Nên tránh</p>
        <div class="flex flex-wrap gap-1.5">
          {quality.badFor.map(b => <span class="badge-red">{b}</span>)}
        </div>
      </div>
    )}
  </div>
</section>
)}

<!-- ── QUICK LINKS ───────────────────────────────────────────── -->
<section class="mb-4">
  <p class="section-label mb-2">🔧 Tiện Ích</p>
  <div class="grid grid-cols-3 gap-2">
    {[
      { href:'/gio-hoang-dao', icon:'⏰', label:'Hoàng Đạo' },
      { href:'/chuyen-doi-lich', icon:'🔄', label:'Đổi Lịch' },
      { href:'/tu-van', icon:'🤖', label:'Hỏi AI' },
      { href:'/xem-tuoi-hop', icon:'💑', label:'Hợp Tuổi' },
      { href:'/ban-menh', icon:'🌍', label:'Bản Mệnh' },
      { href:'/van-khan', icon:'🙏', label:'Văn Khấn' },
    ].map(({ href, icon, label }) => (
      <a href={href} class="card flex flex-col items-center py-3 no-underline">
        <span class="text-2xl mb-1">{icon}</span>
        <span class="text-xs font-semibold" style="color:var(--text-2);">{label}</span>
      </a>
    ))}
  </div>
</section>

<!-- SEO -->
<div class="card p-4 mb-4">
  <h2 class="font-semibold text-sm mb-1.5" style="color:var(--text-1);">Lịch Vạn Niên AI — Lịch Âm Dương Việt Nam</h2>
  <p class="text-sm leading-relaxed" style="color:var(--text-3);">
    Xem <strong style="color:var(--text-2);">lịch âm hôm nay</strong> theo thuật toán Hồ Ngọc Đức.
    Tra cứu <strong style="color:var(--text-2);">ngày tốt xấu</strong>, giờ hoàng đạo, tứ trụ can chi.
    Hỗ trợ chọn ngày cưới, khai trương theo âm lịch Việt Nam.
  </p>
</div>

</BaseLayout>
<script is:inline>
(function() {
  // Can chi giờ theo chi ngày và giờ index
  var CAN  = ['Giáp','Ất','Bính','Đinh','Mậu','Kỷ','Canh','Tân','Nhâm','Quý'];
  var CHI  = ['Tý','Sửu','Dần','Mão','Thìn','Tỵ','Ngọ','Mùi','Thân','Dậu','Tuất','Hợi'];
  var TEN_GIO = [
    'Giờ Tý (23-1h)','Giờ Sửu (1-3h)','Giờ Dần (3-5h)',
    'Giờ Mão (5-7h)','Giờ Thìn (7-9h)','Giờ Tỵ (9-11h)',
    'Giờ Ngọ (11-13h)','Giờ Mùi (13-15h)','Giờ Thân (15-17h)',
    'Giờ Dậu (17-19h)','Giờ Tuất (19-21h)','Giờ Hợi (21-23h)',
  ];

  // JDN của ngày hôm nay (tính lúc build, inject qua data attribute)
  // Để đơn giản: dùng toJDN đơn giản inline
  function toJDN(d, m, y) {
    var yy = y, mm = m;
    if (mm <= 2) { yy--; mm += 12; }
    var A = Math.floor(yy / 100);
    var B = 2 - A + Math.floor(A / 4);
    return Math.floor(365.25 * (yy + 4716)) + Math.floor(30.6001 * (mm + 1)) + d + B - 1524;
  }

  function getGioIdx(hour) {
    return Math.floor(((hour + 1) % 24) / 2);
  }

  function getVNHour() {
    // Lấy giờ VN qua sv-SE locale
    try {
      var s = new Date().toLocaleString('sv-SE', { timeZone: 'Asia/Ho_Chi_Minh' });
      return parseInt(s.split(' ')[1].split(':')[0], 10);
    } catch(e) {
      return new Date().getHours();
    }
  }

  function updateGio() {
    var hour    = getVNHour();
    var gioIdx  = getGioIdx(hour);

    // Cập nhật label giờ hiện tại trong Tứ Trụ
    var gioEl   = document.getElementById('gio-canchichi');
    var gioLbl  = document.getElementById('gio-label');

    if (gioEl) {
      // Lấy JDN từ data attribute (được inject bên dưới)
      var jdn = parseInt(document.body.dataset.jdn || '0', 10);
      if (jdn > 0) {
        var canNgay = (jdn + 9) % 10;
        var canGio  = (canNgay % 5 * 2 + gioIdx) % 10;
        gioEl.textContent = CAN[canGio] + ' ' + CHI[gioIdx];
      }
    }
    if (gioLbl) {
      gioLbl.textContent = TEN_GIO[gioIdx];
    }

    // Cập nhật highlight giờ hoàng đạo
    var rows = document.querySelectorAll('[data-gio-idx]');
    rows.forEach(function(row) {
      var idx     = parseInt(row.dataset.gioIdx, 10);
      var nowBadge = row.querySelector('#now-badge');
      var dot      = row.querySelector('.w-2');

      // Xóa state cũ
      row.classList.remove('current-gio');

      if (idx === gioIdx) {
        row.classList.add('current-gio');
        if (!nowBadge) {
          // Thêm badge "Hiện tại" nếu chưa có
          var nameEl = row.querySelector('p');
          if (nameEl) {
            var badge = document.createElement('span');
            badge.id = 'now-badge';
            badge.textContent = 'Hiện tại';
            badge.style.cssText = 'font-size:9px;margin-left:6px;padding:1px 6px;border-radius:4px;background:var(--red);color:white;';
            nameEl.appendChild(badge);
          }
        }
        // Scroll giờ hiện tại vào view (nếu off-screen)
        row.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        // Xóa badge cũ nếu giờ đã qua
        var old = row.querySelector('#now-badge');
        if (old) old.remove();
      }
    });
  }

  // Chạy ngay + mỗi 60 giây
  updateGio();
  setInterval(updateGio, 60000);
})();
</script>

<script is:inline define:vars={{ prevPath, nextPath }}>
(function() {
  var sx=0, sy=0;
  document.addEventListener('touchstart', function(e){ sx=e.touches[0].clientX; sy=e.touches[0].clientY; },{passive:true});
  document.addEventListener('touchend', function(e){
    var dx=e.changedTouches[0].clientX-sx, dy=Math.abs(e.changedTouches[0].clientY-sy);
    if(Math.abs(dx)<70||dy>80) return;
    if(e.target.closest('button,a,input,select,.card')) return;
    window.location.href = dx>0 ? prevPath : nextPath;
  },{passive:true});
})();
</script>
