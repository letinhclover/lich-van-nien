---
// ============================================================
// src/pages/lich/[year]/[month]/[day].astro
// 1825 trang tĩnh — mỗi trang = 1 URL = 1 cơ hội rank Google
// ============================================================

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import {
  getAllDayParams, validateDayParams,
  solarToPath, prevDayPath, nextDayPath, buildSolarDate, THU_SHORT,
} from '../../../../lib/dateUtils';
import {
  solarToLunar, getDayInfo,
} from '../../../../lib/amlich';
import { SITE } from '../../../../lib/constants';
import { createDayPageSchema } from '../../../../lib/schema';
import Breadcrumb  from '../../../../components/Breadcrumb.astro';
import RelatedDays from '../../../../components/RelatedDays.astro';
import ShareDayImage  from '../../../../components/ShareDayImage';
import SaoTrucBadge   from '../../../../components/SaoTrucBadge.astro';

// ─── SSG: generate 1826 paths ────────────────────────────────
export function getStaticPaths() {
  return getAllDayParams();
}

// ─── Params ──────────────────────────────────────────────────
const { year, month, day } = Astro.params;
const validated = validateDayParams(year, month, day);
if (!validated.valid) return Astro.redirect('/404');
const { y, m, d } = validated;

// ─── Dữ liệu ngày ────────────────────────────────────────────
const solar   = buildSolarDate(d, m, y);
const lunar   = solarToLunar(d, m, y);
const info    = getDayInfo(d, m, y);
const { canChi, quality, hours } = info;

// Derived
const lunarFull   = `${lunar.leap ? 'Nhuận ' : ''}${lunar.day} tháng ${lunar.month} năm ${lunar.yearName}`;
const lunarShort  = `${lunar.leap ? 'Nhuận ' : ''}${lunar.day}/${lunar.month}`;
const goodHoursStr = hours.filter(h => h.isHoangDao).slice(0, 4).map(h => h.tenGio.split(' (')[0]).join(', ');

const scoreBadgeStyle = quality.score >= 4
  ? 'background:var(--green-pale);color:var(--green);border:1px solid rgba(29,158,117,0.3);'
  : quality.score === 3
    ? 'background:var(--gold-pale);color:var(--gold-dark);border:1px solid rgba(241,196,15,0.3);'
    : 'background:var(--red-pale);color:var(--red);border:1px solid var(--border-red);';
const scoreLabel  = quality.score >= 4 ? 'Ngày Tốt' : quality.score === 3 ? 'Bình Thường' : 'Ngày Xấu';
// Inline: Rằm / Mùng Một badge
const ramMungBadge: string | null = lunar.day === 15 ? '🌕 Ngày Rằm' : lunar.day === 1 ? '🌑 Mùng Một' : null;

// Inline: Ngày lễ / Ngày Vía
interface _NgayDB { icon: string; ten: string; }
const _LUNAR_DB: Array<{ld:number;lm:number;icon:string;ten:string}> = [
  {ld:1, lm:1,  icon:'🧧',ten:'Tết Nguyên Đán'},
  {ld:15,lm:1,  icon:'🌕',ten:'Rằm tháng Giêng'},
  {ld:10,lm:3,  icon:'👑',ten:'Giỗ Tổ Hùng Vương'},
  {ld:5, lm:5,  icon:'🍑',ten:'Tết Đoan Ngọ'},
  {ld:15,lm:7,  icon:'🙏',ten:'Lễ Vu Lan'},
  {ld:15,lm:8,  icon:'🥮',ten:'Tết Trung Thu'},
  {ld:19,lm:2,  icon:'🙏',ten:'Vía Quan Thế Âm'},
  {ld:19,lm:6,  icon:'🙏',ten:'Vía Quan Thế Âm (hè)'},
  {ld:19,lm:9,  icon:'🙏',ten:'Vía Quan Thế Âm (thu)'},
  {ld:23,lm:12, icon:'🔥',ten:'Vía Ông Táo'},
  {ld:30,lm:12, icon:'🍽️',ten:'Tất Niên'},
];
const _SOLAR_DB: Array<{sd:number;sm:number;icon:string;ten:string}> = [
  {sd:1, sm:1, icon:'🎉',ten:'Tết Dương Lịch'},
  {sd:30,sm:4, icon:'🇻🇳',ten:'Ngày Giải Phóng 30/4'},
  {sd:1, sm:5, icon:'✊',ten:'Ngày Lao Động'},
  {sd:2, sm:9, icon:'🇻🇳',ten:'Quốc Khánh 2/9'},
];
const allDacBiet: _NgayDB[] = [
  ..._LUNAR_DB.filter(x => x.ld === lunar.day && x.lm === lunar.month),
  ..._SOLAR_DB.filter(x => x.sd === d && x.sm === m),
];

// Lịch tuần: 7 ngày xung quanh ngày này
const weekDays = Array.from({ length: 7 }, (_, i) => {
  const ms  = Date.UTC(y, m - 1, d) + (i - solar.weekday) * 86400000;
  const dt  = new Date(ms);
  const dd2 = dt.getUTCDate(), mm2 = dt.getUTCMonth() + 1, yy2 = dt.getUTCFullYear();
  return {
    dd: dd2, mm: mm2, yy: yy2,
    dow: dt.getUTCDay(),
    isThis: dd2 === d && mm2 === m && yy2 === y,
    path: solarToPath(dd2, mm2, yy2),
  };
});

// Paths
const prevPath  = prevDayPath(d, m, y);
const nextPath  = nextDayPath(d, m, y);
const thangPath = `/lich/thang/${year}/${month}`;
const canonical = `${SITE.baseUrl}/lich/${year}/${month}/${day}`;
const dateStr   = `${year}-${month}-${day}`;

// JSON-LD — phải sau canonical
const daySchema = createDayPageSchema(info, canonical);
const jsonLd     = daySchema;

// ─── SEO ─────────────────────────────────────────────────────
const title = `Lịch âm ngày ${d}/${m}/${y} — ${canChi.ngay.display} ${scoreLabel} | Lịch Vạn Niên AI`.slice(0, 60);
const description = (
  `Ngày ${d}/${m}/${y} (${solar.weekdayLabel}) = ${lunarFull}. ` +
  `Can chi ${canChi.ngay.display}. ${quality.label}. ` +
  `Giờ hoàng đạo: ${goodHoursStr}.`
).slice(0, 160);

// JSON-LD handled by createDayPageSchema below
---

<BaseLayout
  {title}
  {description}
  canonicalUrl={canonical}
  prevUrl={`${SITE.baseUrl}${prevPath}`}
  nextUrl={`${SITE.baseUrl}${nextPath}`}
  {jsonLd}
>

  <Breadcrumb items={[
    { label:'Trang chủ', href:'/' },
    { label:`T.${m}/${y}`, href:thangPath },
    { label:`${d}/${m}` },
  ]} />

  <!-- ── HERO ──────────────────────────────────────────────── -->
  <section class="mb-3">
    <div class="card">
      <div class="h-1" style={`background:${quality.color};`}></div>
      <div class="p-4">

        <!-- Day + Score -->
        <div class="flex items-end justify-between mb-4">
          <div>
            <p class="text-sm mb-1" style="color:var(--text-3);">
              {solar.weekdayLabel}
            </p>
            <div class="flex items-baseline gap-1.5">
              <span class="day-number">{String(d).padStart(2,'0')}</span>
              <div style="padding-bottom:0.5rem;">
                <span class="text-sm font-medium block" style="color:var(--text-3);">tháng {m}</span>
                <span class="text-sm font-medium block" style="color:var(--text-4);">năm {y}</span>
              </div>
            </div>
          </div>
          <div class="flex flex-col items-center justify-center w-[60px] h-[60px] rounded-2xl"
            style={`background:${quality.color}12;border:1.5px solid ${quality.color}40;`}>
            <span class="font-display font-bold text-2xl leading-none" style={`color:${quality.color};`}>
              {quality.score}
            </span>
            <span class="text-[9px] font-medium mt-0.5" style="color:var(--text-4);">/5 sao</span>
          </div>
        </div>

        <!-- Lunar -->
        <div class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl mb-3"
          style="background:var(--bg-surface);">
          <span class="text-xl">🌙</span>
          <div>
            <p class="text-[10px] font-semibold uppercase tracking-wide" style="color:var(--text-4);">Âm lịch</p>
            <p class="font-semibold text-sm" style="color:var(--text-1);">{lunarFull}</p>
          </div>
        </div>

        <!-- Badges -->
        <div class="flex flex-wrap gap-1.5">
          <span class="badge-gold">Ngày {canChi.ngay.display}</span>
          {quality.score >= 4 && <span class="badge-green">✓ Ngày Tốt</span>}
          {quality.score <= 2 && <span class="badge-red">Ngày Xấu</span>}
          {quality.isTamNuong && <span class="badge-red">⚠ Tam Nương</span>}
          {quality.isNguyetKy  && <span class="badge-red">⚠ Nguyệt Kỵ</span>}
          {ramMungBadge && <span class="badge-gold">{ramMungBadge}</span>}
          {allDacBiet.map((db: {icon:string;ten:string}) => (
            <span class="badge-gold">{db.icon} {db.ten}</span>
          ))}
          <SaoTrucBadge {day} {month} {year} />
        </div>
      </div>
    </div>
  </section>

  <!-- ── TỨ TRỤ ────────────────────────────────────────────── -->
  <section class="mb-3">
    <p class="section-label mb-2">🔮 Tứ Trụ Can Chi</p>
    <div class="card">
      <div class="grid grid-cols-2">
        {([
          { label:'NĂM',   cc: canChi.nam   },
          { label:'THÁNG', cc: canChi.thang },
          { label:'NGÀY',  cc: canChi.ngay  },
          { label:'GIỜ',   cc: canChi.gio   },
        ] as const).map(({ label, cc }, i) => (
          <div class="p-4" style={`${i<2?'border-bottom:1px solid var(--border);':''}${i%2===0?'border-right:1px solid var(--border);':''}`}>
            <p class="section-label mb-1">{label}</p>
            <p class="font-display font-bold text-lg leading-tight" style="color:var(--text-1);">{cc.display}</p>
            <p class="text-xs mt-0.5" style="color:var(--text-3);">{cc.nguHanh}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── GIỜ HOÀNG ĐẠO ─────────────────────────────────────── -->
  <section class="mb-3">
    <p class="section-label mb-2">⏰ Giờ Hoàng Đạo</p>
    <div class="card">
      {hours.map(h => (
        <div class="flex items-center justify-between px-4 py-3"
          style={`border-bottom:1px solid var(--border);${h.isHoangDao?'background:var(--green-pale);':''}`}>
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full shrink-0"
              style={`background:${h.isHoangDao?'var(--green)':'var(--border)'};`}></div>
            <div>
              <p class="text-sm font-semibold" style="color:var(--text-1);">{h.tenGio}</p>
              <p class="text-xs" style="color:var(--text-3);">{h.canChi}</p>
            </div>
          </div>
          <span class="text-xs font-semibold px-2 py-1 rounded-lg"
            style={h.isHoangDao?'color:var(--green);background:var(--green-pale);':'color:var(--text-4);'}>
            {h.isHoangDao ? 'Hoàng Đạo' : 'Hắc Đạo'}
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── NÊN LÀM / TRÁNH ───────────────────────────────────── -->
  <section class="mb-3">
    <p class="section-label mb-2">📋 Nên làm & Nên tránh</p>
    <div class="card p-4">
      <div class="mb-3 pb-3" style="border-bottom:1px solid var(--border);">
        <p class="section-label mb-2">Sao trực nhật</p>
        <SaoTrucBadge {day} {month} {year} expanded={true} />
      </div>
      {quality.goodFor.length > 0 && (
        <div class="mb-3">
          <p class="section-label mb-2">✅ Nên làm</p>
          <div class="flex flex-wrap gap-1.5">
            {quality.goodFor.map(g => <span class="badge-green">{g}</span>)}
          </div>
        </div>
      )}
      {quality.badFor.length > 0 && (
        <div>
          <p class="section-label mb-2">❌ Nên tránh</p>
          <div class="flex flex-wrap gap-1.5">
            {quality.badFor.map(b => <span class="badge-red">{b}</span>)}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ── RELATED + NAV ─────────────────────────────────────── -->
  <RelatedDays {day} {month} {year} />

  <nav class="mb-3">
    <!-- Main nav: prev/today/next -->
    <div class="flex gap-2 mb-2">
      <a href={prevPath} class="flex-1 btn-secondary justify-center py-3 text-sm">←</a>
      <a href="/" class="flex-1 btn-primary justify-center py-3 text-sm">🏠 Hôm nay</a>
      <a href={nextPath} class="flex-1 btn-secondary justify-center py-3 text-sm">→</a>
    </div>
    <a href={thangPath} class="btn-secondary w-full justify-center py-2.5 text-sm">📅 Lịch tháng {m}/{y}</a>
  </nav>

  <!-- ── SHARE ─────────────────────────────────────────────── -->
  <div class="mb-3">
    <ShareDayImage
      {day} {month} {year}
      lunar={lunarFull}
      canChi={canChi.ngay.display}
      score={quality.score}
      label={quality.label}
      goodFor={quality.goodFor}
      url={canonical}
      client:visible
    />
  </div>

  <!-- ── SEO TEXT ──────────────────────────────────────────── -->
  <div class="card p-4 mb-2">
    <h2 class="font-semibold text-sm mb-1.5" style="color:var(--text-1);">
      Lịch âm ngày {d} tháng {m} năm {y}
    </h2>
    <p class="text-sm leading-relaxed" style="color:var(--text-3);">
      Ngày {d}/{m}/{y} ({solar.weekdayLabel}) âm lịch là <strong style="color:var(--text-2);">{lunarFull}</strong>.
      Can chi ngày <strong style="color:var(--text-2);">{canChi.ngay.display}</strong>,
      tháng <strong style="color:var(--text-2);">{canChi.thang.display}</strong>,
      năm <strong style="color:var(--text-2);">{canChi.nam.display}</strong>.
      {quality.label}. {goodHoursStr && `Giờ hoàng đạo: ${goodHoursStr}.`}
    </p>
  </div>

</BaseLayout>

<script is:inline>
// Swipe left/right to navigate days
(function() {
  var startX = 0, startY = 0;
  var PREV = document.querySelector('a[href*="prevPath"]');

  document.addEventListener('touchstart', function(e) {
    startX = e.touches[0].clientX;
    startY = e.touches[0].clientY;
  }, { passive: true });

  document.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - startX;
    var dy = Math.abs(e.changedTouches[0].clientY - startY);
    // Only horizontal swipes > 60px with small vertical drift
    if (Math.abs(dx) < 60 || dy > 60) return;
    // Don't trigger on interactive elements
    var target = e.target;
    if (target.closest('button,a,input,textarea,select')) return;

    var nav = document.querySelector('nav');
    if (!nav) return;
    var links = nav.querySelectorAll('a');
    var prevLink = links[0];
    var nextLink = links[links.length - 1];

    if (dx > 0 && prevLink) {
      // Swipe right → previous day
      window.location.href = prevLink.href;
    } else if (dx < 0 && nextLink) {
      // Swipe left → next day
      window.location.href = nextLink.href;
    }
  }, { passive: true });
})();
</script>
