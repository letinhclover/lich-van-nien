---
// src/pages/lich/[year]/[month]/[day].astro — dùng đúng API amlich.ts

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import {
  getAllDayParams, validateDayParams,
  solarToPath, prevDayPath, nextDayPath, buildSolarDate,
} from '../../../../lib/dateUtils';
import {
  solarToLunar, toJDN,
  getCanChi, getDayQuality, getHoangDao,
} from '../../../../lib/amlich';
import { SITE } from '../../../../lib/constants';

export function getStaticPaths() {
  return getAllDayParams();
}

const { year, month, day } = Astro.params;
const validated = validateDayParams(year, month, day);
if (!validated.valid) return Astro.redirect('/404');
const { y, m, d } = validated;

const solar   = buildSolarDate(d, m, y);
const lunar   = solarToLunar(d, m, y);
const canChi  = getCanChi(d, m, y);
const quality = getDayQuality(d, m, y);
const hours   = getHoangDao(d, m, y);

const lunarLabel   = `${lunar.leap ? 'Nhuận ' : ''}${lunar.day}/${lunar.month}`;
const hoangDaoGio  = hours.filter(h => h.isHoangDao);

const title = `${solar.weekdayLabel} ${d}/${m}/${y} — Ngày ${canChi.ngay.display} Năm ${canChi.nam.display} | Lịch Vạn Niên`.slice(0, 60);
const description = (`Lịch âm ${d}/${m}/${y}: ngày ${lunarLabel} tháng ${lunar.month} năm ${canChi.nam.display}. Can chi ${canChi.ngay.display}. ${quality.label}. Giờ hoàng đạo: ${hoangDaoGio.slice(0,3).map(h=>h.tenGio.split(' ')[0]).join(', ')}.`).slice(0, 160);
const canonical    = `${SITE.baseUrl}/lich/${year}/${month}/${day}`;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type':'ListItem', position:1, name:'Trang chủ', item: SITE.baseUrl },
      { '@type':'ListItem', position:2, name:`Tháng ${m}/${y}`, item:`${SITE.baseUrl}/lich/thang/${year}/${month}` },
      { '@type':'ListItem', position:3, name:`${d}/${m}/${y}`, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: `Ngày ${d}/${m}/${y} âm lịch là ngày mấy?`,
        acceptedAnswer: { '@type': 'Answer', text: `Ngày ${d}/${m}/${y} là ngày ${lunarLabel} tháng ${lunar.month}${lunar.leap?' nhuận':''} năm ${canChi.nam.display}.` },
      },
      {
        '@type': 'Question',
        name: `Ngày ${d}/${m}/${y} có tốt không?`,
        acceptedAnswer: { '@type': 'Answer', text: `${quality.label} (${quality.score}/5). Nên làm: ${quality.goodFor.slice(0,3).join(', ')}.` },
      },
    ],
  },
];

const stars = (r: number) => '★'.repeat(r) + '☆'.repeat(5 - r);
const prevPath = prevDayPath(d, m, y);
const nextPath = nextDayPath(d, m, y);
---

<BaseLayout {title} {description} {canonical} {schema}>

  <nav aria-label="Breadcrumb" class="flex flex-wrap items-center gap-1 text-xs mb-4" style="color:var(--text-3);">
    <a href="/" class="no-underline hover:underline" style="color:var(--text-3);">🏠 Trang chủ</a>
    <span>›</span>
    <a href={`/lich/thang/${year}/${month}`} class="no-underline hover:underline" style="color:var(--text-3);">Tháng {m}/{y}</a>
    <span>›</span>
    <span style="color:var(--text-1);font-weight:600;">{d}/{m}/{y}</span>
  </nav>

  <!-- Hero -->
  <div class="card overflow-hidden mb-4">
    <div class="h-1.5" style={`background: ${quality.color};`}></div>
    <div class="p-4">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <p class="section-label mb-1">{solar.weekdayLabel} · {d}/{m}/{y}</p>
          <h1 class="font-display font-bold text-2xl leading-tight mb-1" style="color:var(--text-1);">
            Ngày {canChi.ngay.display}
          </h1>
          <p class="text-sm" style="color:var(--text-2);">
            Âm lịch: <strong>{lunarLabel}</strong> tháng {lunar.month}
            {lunar.leap && <span class="badge-red ml-1 text-[10px]">Nhuận</span>}
            · Năm <strong>{canChi.nam.display}</strong>
          </p>
        </div>
        <div class="flex flex-col items-center justify-center w-16 h-16 rounded-2xl shrink-0"
          style={`border:2px solid ${quality.color};background:${quality.color}18;`}>
          <span class="font-display font-bold text-2xl" style={`color:${quality.color};`}>{quality.score}</span>
          <span class="text-[9px]" style="color:var(--text-3);">/5 điểm</span>
        </div>
      </div>
      <div class="flex flex-wrap gap-1.5 mt-3">
        <span class="badge-gold">Ngày {canChi.ngay.display}</span>
        <span class="badge-gold">Tháng {canChi.thang.display}</span>
        <span class="badge-gold">Năm {canChi.nam.display}</span>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold"
          style={`background:${quality.color}15;color:${quality.color};border:1px solid ${quality.color}40;`}>
          {quality.label}
        </span>
        {quality.isTamNuong && <span class="badge-red">⚠ Tam Nương</span>}
        {quality.isNguyetKy  && <span class="badge-red">⚠ Nguyệt Kỵ</span>}
      </div>
    </div>
  </div>

  <!-- Tứ Trụ -->
  <div class="card overflow-hidden mb-4">
    <div class="px-4 py-3 border-b" style="border-color:var(--border);">
      <h2 class="font-bold text-sm" style="color:var(--text-1);">🔮 Tứ Trụ Can Chi</h2>
    </div>
    <div class="grid grid-cols-2">
      {([['Năm', canChi.nam], ['Tháng', canChi.thang], ['Ngày', canChi.ngay], ['Giờ', canChi.gio]] as const).map(([label, cc], i) => (
        <div class:list={['p-3 border-b', i % 2 === 0 ? 'border-r' : '']} style="border-color:var(--border);">
          <p class="section-label mb-0.5">{label}</p>
          <p class="font-bold text-sm" style="color:var(--text-1);">{cc.display}</p>
          <p class="text-xs" style="color:var(--text-3);">{cc.nguHanh}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Đánh giá -->
  <div class="card p-4 mb-4">
    <h2 class="font-bold text-sm mb-3" style="color:var(--text-1);">📊 Đánh Giá Ngày</h2>
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xl font-bold" style={`color:${quality.color};`}>{stars(quality.score)}</span>
      <span class="font-semibold text-sm" style={`color:${quality.color};`}>{quality.label}</span>
    </div>
    {quality.goodFor.length > 0 && (
      <div class="mb-2">
        <p class="section-label mb-1.5">✅ Nên làm hôm nay</p>
        <div class="flex flex-wrap gap-1.5">
          {quality.goodFor.map(g => <span class="badge-green text-xs">{g}</span>)}
        </div>
      </div>
    )}
    {quality.badFor.length > 0 && (
      <div>
        <p class="section-label mb-1.5">❌ Nên tránh</p>
        <div class="flex flex-wrap gap-1.5">
          {quality.badFor.map(b => <span class="badge-red text-xs">{b}</span>)}
        </div>
      </div>
    )}
  </div>

  <!-- Giờ Hoàng Đạo -->
  <div class="card overflow-hidden mb-4">
    <div class="px-4 py-3 border-b" style="border-color:var(--border);">
      <h2 class="font-bold text-sm" style="color:var(--text-1);">⏰ Giờ Hoàng Đạo</h2>
    </div>
    <div class="p-3 flex flex-col gap-1.5">
      {hours.map(h => (
        <div class="flex items-center justify-between px-3 py-2 rounded-xl"
          style={h.isHoangDao
            ? 'background:var(--green-pale);border:1px solid rgba(29,158,117,0.2);'
            : 'background:var(--bg-surface);opacity:0.65;'}>
          <span class="text-sm font-medium" style="color:var(--text-1);">{h.tenGio}</span>
          <span class="text-xs font-bold" style={h.isHoangDao ? 'color:var(--green);' : 'color:var(--text-3);'}>
            {h.isHoangDao ? 'Hoàng Đạo ✓' : 'Hắc Đạo'}
          </span>
        </div>
      ))}
    </div>
  </div>

  <!-- Prev / Next -->
  <div class="flex gap-3 mb-2">
    <a href={prevPath} class="flex-1 btn-secondary justify-center">← Hôm trước</a>
    <a href={nextPath} class="flex-1 btn-secondary justify-center">Hôm sau →</a>
  </div>

</BaseLayout>
