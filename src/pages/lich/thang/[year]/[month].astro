---
// src/pages/lich/thang/[year]/[month].astro — 60 trang lịch tháng
import BaseLayout    from '../../../../layouts/BaseLayout.astro';
import CalendarGrid  from '../../../../components/CalendarGrid.astro';
import { getAllMonthParams, todayVN } from '../../../../lib/dateUtils';
import { getMonthCalendar } from '../../../../lib/amlich';
import { SITE } from '../../../../lib/constants';

export function getStaticPaths() {
  return getAllMonthParams();
}

const { year, month } = Astro.params;
const y = parseInt(year!);
const m = parseInt(month!);

const THANG_VI = ['','Tháng Một','Tháng Hai','Tháng Ba','Tháng Tư','Tháng Năm','Tháng Sáu','Tháng Bảy','Tháng Tám','Tháng Chín','Tháng Mười','Tháng Mười Một','Tháng Mười Hai'];

const days      = getMonthCalendar(y, m);
const today     = todayVN();
const currentDay = (today.year === y && today.month === m) ? today.day : undefined;

// Ngày tốt trong tháng (score >= 4)
const goodDays  = days.filter(d => d.quality.score >= 4);
const canonical = `${SITE.baseUrl}/lich/thang/${year}/${month}`;
const title     = `Lịch tháng ${m}/${y} — Ngày tốt xấu ${THANG_VI[m] ?? ''} năm ${y} | Lịch Vạn Niên`.slice(0,60);
const description = `Lịch âm tháng ${m}/${y}: xem ngày tốt xấu từng ngày, giờ hoàng đạo, can chi. ${goodDays.length} ngày tốt trong tháng ${m}/${y}.`.slice(0,160);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type':    'BreadcrumbList',
  itemListElement: [
    { '@type':'ListItem', position:1, name:'Trang chủ',             item: SITE.baseUrl },
    { '@type':'ListItem', position:2, name:`Tháng ${m}/${y}`, item: canonical },
  ],
};
---
<BaseLayout {title} {description} canonicalUrl={canonical} {jsonLd}>

  <nav class="flex flex-wrap items-center gap-1 text-xs mb-3" style="color:var(--text-3);">
    <a href="/" class="no-underline hover:underline" style="color:var(--text-3);">Trang chủ</a>
    <span>›</span>
    <span style="color:var(--text-1);font-weight:600;">Tháng {m}/{y}</span>
  </nav>

  <h1 class="font-display font-bold text-xl mb-4" style="color:var(--text-1);">
    Lịch tháng {m}/{y} — Ngày tốt xấu {THANG_VI[m]}
  </h1>

  <CalendarGrid {year} {month} {days} {currentDay} />

  <!-- Danh sách ngày tốt -->
  {goodDays.length > 0 && (
    <div class="card p-4 mt-4">
      <h2 class="font-bold text-sm mb-3" style="color:var(--text-1);">✅ Ngày tốt tháng {m}/{y}</h2>
      <div class="flex flex-wrap gap-2">
        {goodDays.map(d => (
          <a href={`/lich/${year}/${month}/${String(d.solar.day).padStart(2,'0')}`}
            class="badge-green text-xs no-underline hover:opacity-80">
            {d.solar.day}/{m} · {d.canChi.ngay.display}
          </a>
        ))}
      </div>
    </div>
  )}

</BaseLayout>
