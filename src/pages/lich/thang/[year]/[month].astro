---
// src/pages/lich/thang/[year]/[month].astro

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import {
  getAllMonthParams, buildMonthCalendar,
  solarToPath, prevMonth, nextMonth,
} from '../../../../lib/dateUtils';
import { solarToLunar, getDayQuality } from '../../../../lib/amlich';
import { SITE, THU_SHORT } from '../../../../lib/constants';

export function getStaticPaths() {
  return getAllMonthParams();
}

const { year, month } = Astro.params;
const y = parseInt(year!);
const m = parseInt(month!);

const calendar = buildMonthCalendar(y, m);
const prev     = prevMonth(m, y);
const next     = nextMonth(m, y);

// Pre-compute chất lượng ngày
interface DayData {
  d: number;
  lunarDay: number;
  lunarMonth: number;
  lunarLeap: boolean;
  score: number;
  color: string;
  label: string;
  dotColor: string;
}

const dayData: DayData[] = Array.from({ length: calendar.totalDays }, (_, i) => {
  const d     = i + 1;
  const lunar = solarToLunar(d, m, y);
  const q     = getDayQuality(d, m, y);
  const dot   = q.score >= 4 ? 'var(--green)' : q.score <= 2 ? 'var(--red)' : 'var(--gold-dark)';
  return {
    d,
    lunarDay:   lunar.day,
    lunarMonth: lunar.month,
    lunarLeap:  lunar.leap,
    score:      q.score,
    color:      q.color,
    label:      q.label,
    dotColor:   dot,
  };
});

// Map day number → data cho lookup nhanh
const dataMap = new Map<number, DayData>(dayData.map(d => [d.d, d]));

const title       = `Lịch Tháng ${m} Năm ${y} — Lịch Âm Đầy Đủ | Lịch Vạn Niên`.slice(0, 60);
const description = `Lịch tháng ${m}/${y}: ngày tốt xấu, âm lịch từng ngày, can chi. Bảng lịch âm dương tháng ${m} năm ${y} chính xác.`.slice(0, 160);
const canonical   = `${SITE.baseUrl}/lich/thang/${year}/${month}`;

const schema = {
  '@context': 'https://schema.org',
  '@type':    'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Trang chủ',       item: SITE.baseUrl },
    { '@type': 'ListItem', position: 2, name: `Tháng ${m}/${y}`, item: canonical },
  ],
};

const prevHref = `/lich/thang/${prev.year}/${String(prev.month).padStart(2,'0')}`;
const nextHref = `/lich/thang/${next.year}/${String(next.month).padStart(2,'0')}`;

const goodDays = dayData.filter(d => d.score >= 4);
---

<BaseLayout {title} {description} {canonical} {schema}>

  <nav class="flex items-center gap-1 text-xs mb-4" style="color:var(--text-3);">
    <a href="/" class="no-underline hover:underline" style="color:var(--text-3);">🏠 Trang chủ</a>
    <span>›</span>
    <span style="color:var(--text-1);font-weight:600;">Tháng {m}/{y}</span>
  </nav>

  <!-- Nav tháng -->
  <div class="flex items-center justify-between mb-4">
    <a href={prevHref} class="btn-secondary py-2 px-3 text-sm">
      ← T{prev.month}/{prev.year}
    </a>
    <h1 class="font-display font-bold text-xl text-center" style="color:var(--text-1);">
      Tháng {m} · {y}
    </h1>
    <a href={nextHref} class="btn-secondary py-2 px-3 text-sm">
      T{next.month}/{next.year} →
    </a>
  </div>

  <!-- Legend -->
  <div class="flex gap-4 mb-3 text-xs" style="color:var(--text-3);">
    <span>🟢 Tốt (≥4)</span>
    <span>🟡 Bình thường (3)</span>
    <span>🔴 Xấu (≤2)</span>
  </div>

  <!-- Grid lịch -->
  <div class="card overflow-hidden mb-4">

    <!-- Header thứ -->
    <div class="grid grid-cols-7" style="background:var(--bg-surface);border-bottom:1px solid var(--border);">
      {THU_SHORT.map((t, i) => (
        <div
          class="py-2 text-center text-xs font-bold"
          style={i === 0
            ? 'color:var(--red);'
            : i === 6
              ? 'color:var(--gold-dark);'
              : 'color:var(--text-3);'}
        >
          {t}
        </div>
      ))}
    </div>

    <!-- Các hàng -->
    {calendar.grid.map(row => (
      <div class="grid grid-cols-7" style="border-bottom:1px solid var(--border);">
        {row.map(cell => {
          if (!cell) {
            return (
              <div
                class="p-2 min-h-[58px]"
                style="background:var(--bg-surface);opacity:0.3;border-right:1px solid var(--border);"
              />
            );
          }

          const data    = dataMap.get(cell.day);
          const isSun   = cell.weekday === 0;
          const isSat   = cell.weekday === 6;
          const numColor = isSun ? 'color:var(--red);'
                         : isSat ? 'color:var(--gold-dark);'
                         : 'color:var(--text-1);';

          return (
            <a
              href={solarToPath(cell.day, m, y)}
              class="p-1.5 min-h-[58px] flex flex-col no-underline hover:bg-[var(--bg-surface)] relative"
              style="border-right:1px solid var(--border);"
            >
              {data && (
                <span
                  class="absolute top-1 right-1 w-1.5 h-1.5 rounded-full"
                  style={`background:${data.dotColor};`}
                />
              )}

              <span class="font-bold text-sm leading-none" style={numColor}>
                {cell.day}
              </span>

              {data && (
                <span class="text-[9px] mt-0.5 leading-none" style="color:var(--text-3);">
                  {data.lunarDay === 1 ? `M.${data.lunarMonth}` : data.lunarDay}
                </span>
              )}
            </a>
          );
        })}
      </div>
    ))}
  </div>

  <!-- Ngày tốt trong tháng -->
  <div class="card p-4 mb-4">
    <h2 class="font-bold text-sm mb-3" style="color:var(--text-1);">
      ✅ Ngày tốt tháng {m}/{y}
    </h2>

    {goodDays.length > 0 ? (
      <div class="flex flex-wrap gap-2">
        {goodDays.map(d => (
          <a
            href={solarToPath(d.d, m, y)}
            class="badge-green text-xs no-underline hover:opacity-80"
          >
            {d.d}/{m} — {d.label}
          </a>
        ))}
      </div>
    ) : (
      <p class="text-sm" style="color:var(--text-3);">
        Không có ngày đặc biệt tốt tháng này.
      </p>
    )}
  </div>

</BaseLayout>
