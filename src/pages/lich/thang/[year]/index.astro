---
// src/pages/lich/thang/[year]/index.astro
// Redirect /lich/thang/2026 → /lich/thang/2026/03
import { todayVN } from '../../../../lib/dateUtils';
import { SSG_START_YEAR, SSG_END_YEAR } from '../../../../lib/constants';

export function getStaticPaths() {
  const paths = [];
  for (let y = SSG_START_YEAR; y <= SSG_END_YEAR; y++) {
    paths.push({ params: { year: String(y) } });
  }
  return paths;
}

const { year } = Astro.params;
const y = parseInt(year ?? '');
const today = todayVN();
const targetMonth = y === today.year ? today.month : 1;
const monthStr = String(targetMonth).padStart(2, '0');

return Astro.redirect(`/lich/thang/${year}/${monthStr}`, 302);
---
