---
// src/pages/blog/index.astro — Danh sách bài viết blog
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../lib/constants';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const canonical  = `${SITE.baseUrl}/blog`;
const title      = 'Blog Lịch Vạn Niên — Phong thủy, lịch âm, ngày tốt xấu | Lịch Vạn Niên'.slice(0,60);
const description = 'Bài viết về lịch âm, phong thủy, ngày tốt xấu, giờ hoàng đạo, can chi. Kiến thức lịch pháp Việt Nam từ Lịch Vạn Niên AI.';
---

<BaseLayout {title} {description} canonicalUrl={canonical}>

  <Breadcrumb items={[
    { label: 'Trang chủ', href: '/' },
    { label: 'Blog' },
  ]} />

  <h1 class="font-display font-bold text-2xl mb-1" style="color:var(--text-1);">
    📝 Blog Lịch Vạn Niên
  </h1>
  <p class="text-sm mb-5" style="color:var(--text-2);">
    Kiến thức về lịch âm, phong thủy, ngày tốt xấu và lịch pháp Việt Nam.
  </p>

  <div class="flex flex-col gap-3">
    {posts.map(post => (
      <a href={`/blog/${post.slug}`}
        class="card p-4 no-underline hover:shadow-md transition-shadow">
        <p class="text-xs mb-1" style="color:var(--text-4);">
          {post.data.pubDate.toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric' })}
        </p>
        <h2 class="font-bold text-base mb-1" style="color:var(--text-1);">
          {post.data.title}
        </h2>
        <p class="text-sm" style="color:var(--text-3);">{post.data.description}</p>
        <div class="flex gap-1.5 flex-wrap mt-2">
          {post.data.keywords.slice(0,3).map(kw => (
            <span class="text-[10px] px-2 py-0.5 rounded-full" style="background:var(--bg-surface);color:var(--text-3);">{kw}</span>
          ))}
        </div>
      </a>
    ))}
  </div>

</BaseLayout>
