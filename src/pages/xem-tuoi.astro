---
// src/pages/xem-tuoi.astro — Xem tuổi đặt tên con
import BaseLayout from '../layouts/BaseLayout.astro';
import XemTuoi    from '../components/XemTuoi';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE }   from '../lib/constants';
import { todayVN } from '../lib/dateUtils';

const { year } = todayVN();
const title       = `Xem tuổi đặt tên con theo năm sinh ${year} | Lịch Vạn Niên AI`.slice(0, 60);
const description = `Xem tuổi đặt tên con theo tuổi cha mẹ, ngũ hành năm sinh. AI gợi ý tên đẹp hợp mệnh. Miễn phí, theo lịch pháp Việt Nam.`.slice(0, 160);
const canonical   = `${SITE.baseUrl}/xem-tuoi`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type':    'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name:    'Xem tuổi đặt tên con dựa trên gì?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:    'Dựa trên can chi năm sinh của con và cha mẹ, ngũ hành tương sinh tương khắc theo lịch pháp Việt Nam. AI phân tích và gợi ý bộ chữ phù hợp ngũ hành.',
      },
    },
    {
      '@type': 'Question',
      name:    'Đặt tên con theo năm sinh có quan trọng không?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:    'Theo quan niệm phong thủy truyền thống Việt Nam, tên con nên hợp với ngũ hành năm sinh để mang lại may mắn. Thông tin này mang tính tham khảo theo phong tục.',
      },
    },
  ],
};
---

<BaseLayout {title} {description} canonicalUrl={canonical} {jsonLd}>

  <Breadcrumb items={[
    { label: 'Trang chủ', href: '/' },
    { label: 'Xem tuổi đặt tên con' },
  ]} />

  <h1 class="font-display font-bold text-2xl mb-2" style="color:var(--text-1);">
    👶 Xem tuổi đặt tên con theo tuổi cha mẹ
  </h1>
  <p class="text-sm mb-5 leading-relaxed" style="color:var(--text-2);">
    Nhập năm sinh cha mẹ và năm dự sinh con. AI phân tích can chi, ngũ hành
    và gợi ý tên đẹp hợp mệnh theo lịch pháp Việt Nam.
  </p>

  <XemTuoi client:load />

  <!-- SEO text -->
  <div class="card p-4 mt-5 mb-2">
    <h2 class="font-bold text-sm mb-2" style="color:var(--text-1);">
      Xem tuổi đặt tên con theo phong thuỷ
    </h2>
    <p class="text-sm leading-relaxed" style="color:var(--text-2);">
      Theo quan niệm phong thủy Việt Nam, tên con nên chọn các chữ có bộ thủ hoặc
      ý nghĩa phù hợp với ngũ hành năm sinh. Tên hợp mệnh giúp con phát triển thuận lợi
      theo niềm tin dân gian truyền thống.
    </p>
  </div>

</BaseLayout>
