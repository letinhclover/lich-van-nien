---
// src/pages/van-trinh/index.astro — Báo cáo vận trình năm 2027
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import VanTrinhForm from '../../components/VanTrinhForm';
import { SITE } from '../../lib/constants';
import { todayVN } from '../../lib/dateUtils';

const { year } = todayVN();
const canonical  = `${SITE.baseUrl}/van-trinh`;
const title      = `Báo cáo vận trình năm 2027 theo tuổi — Miễn phí | Lịch Vạn Niên`.slice(0,60);
const description = `Nhập năm sinh, AI phân tích vận trình năm 2027: tài lộc, sự nghiệp, tình duyên, sức khoẻ, tháng tốt. Báo cáo đầy đủ miễn phí.`.slice(0,160);
---

<BaseLayout {title} {description} canonicalUrl={canonical}>

  <Breadcrumb items={[
    { label: 'Trang chủ', href: '/' },
    { label: 'Vận Trình 2027' },
  ]} />

  <div class="text-center mb-6">
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl text-2xl mb-3"
      style="background:linear-gradient(135deg,#7c3aed,#a78bfa);box-shadow:0 4px 16px rgba(124,58,237,0.3);">
      🔮
    </div>
    <h1 class="font-display font-bold text-2xl mb-1" style="color:var(--text-1);">
      Vận Trình Năm 2027
    </h1>
    <p class="text-sm" style="color:var(--text-3);">
      AI phân tích vận mệnh theo tuổi — tài lộc, sự nghiệp, tình duyên
    </p>
  </div>

  <VanTrinhForm client:load />

  <p class="text-xs text-center mt-4" style="color:var(--text-4);">
    ⚠️ Thông tin mang tính tham khảo theo phong tục truyền thống Việt Nam.
  </p>

</BaseLayout>
