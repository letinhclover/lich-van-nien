---
// src/pages/developer.astro — Public REST API Documentation
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE }   from '../lib/constants';

const canonical  = `${SITE.baseUrl}/developer`;
const title      = 'API Lịch Âm Dương Việt Nam — Tài liệu dành cho lập trình viên'.slice(0,60);
const description = 'Public REST API tra cứu lịch âm Việt Nam: ngày tốt xấu, can chi, giờ hoàng đạo. Miễn phí, không cần đăng ký, CORS enabled.'.slice(0,160);
const BASE = SITE.baseUrl;

const ENDPOINTS = [
  {
    method: 'GET',
    path:   '/api/v1/day',
    desc:   'Thông tin 1 ngày cụ thể',
    params: 'date=YYYY-MM-DD',
    example:`${BASE}/api/v1/day?date=2026-03-14`,
    response: `{
  "day": 14, "month": 3, "year": 2026,
  "weekday": "Thứ Bảy",
  "canChi": "Nhâm Tý",
  "score": 4,
  "label": "Ngày Tốt",
  "goodHours": ["Giờ Tý","Giờ Dần","Giờ Ngọ","Giờ Thân"],
  "isTamNuong": false,
  "isNguyetKy": false,
  "detailUrl": "${BASE}/lich/2026/03/14"
}`,
  },
  {
    method: 'GET',
    path:   '/api/v1/month',
    desc:   'Tất cả ngày trong tháng',
    params: 'year=2026&month=3',
    example:`${BASE}/api/v1/month?year=2026&month=3`,
    response: `{
  "year": 2026, "month": 3, "totalDays": 31,
  "days": [ { "day": 1, "score": 3, ... }, ... ]
}`,
  },
  {
    method: 'GET',
    path:   '/api/v1/good-days',
    desc:   'Chỉ các ngày tốt trong tháng',
    params: 'year=2026&month=3&min_score=4',
    example:`${BASE}/api/v1/good-days?year=2026&month=3&min_score=4`,
    response: `{
  "year": 2026, "month": 3, "minScore": 4,
  "count": 8,
  "days": [ { "day": 4, "score": 4, "canChi": "Ất Mão", ... }, ... ]
}`,
  },
];
---

<BaseLayout {title} {description} canonicalUrl={canonical}>

  <Breadcrumb items={[
    { label: 'Trang chủ', href: '/' },
    { label: 'Developer API' },
  ]} />

  <h1 class="font-display font-bold text-2xl mb-2" style="color:var(--text-1);">
    🔌 Lịch Âm API
  </h1>
  <p class="text-sm mb-5" style="color:var(--text-2);">
    Public REST API — miễn phí, không cần đăng ký, CORS enabled.
  </p>

  <!-- Getting started -->
  <section class="card p-4 mb-5">
    <h2 class="font-bold text-sm mb-3" style="color:var(--text-1);">🚀 Bắt đầu ngay</h2>
    <div class="flex flex-col gap-3 text-sm" style="color:var(--text-2);">
      <div class="flex items-start gap-2.5">
        <span class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0"
          style="background:var(--red);color:white;">1</span>
        <span>Gọi API trực tiếp — không cần API key, không cần đăng ký</span>
      </div>
      <div class="flex items-start gap-2.5">
        <span class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0"
          style="background:var(--red);color:white;">2</span>
        <span>Base URL: <code class="text-xs px-1.5 py-0.5 rounded" style="background:var(--bg-surface);color:var(--red);">{BASE}</code></span>
      </div>
      <div class="flex items-start gap-2.5">
        <span class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0"
          style="background:var(--red);color:white;">3</span>
        <span>Tất cả response dạng JSON, timezone Asia/Ho_Chi_Minh</span>
      </div>
    </div>
  </section>

  <!-- Endpoints -->
  <section class="mb-5">
    <h2 class="section-label mb-3">📋 Endpoints</h2>
    <div class="flex flex-col gap-4">
      {ENDPOINTS.map(ep => (
        <div class="card overflow-hidden">
          <div class="px-4 py-3 flex items-center gap-2 border-b" style="border-color:var(--border);background:var(--bg-surface);">
            <span class="text-xs font-bold px-2 py-0.5 rounded" style="background:var(--green);color:white;">{ep.method}</span>
            <code class="text-sm font-bold" style="color:var(--text-1);">{ep.path}</code>
          </div>
          <div class="p-4">
            <p class="text-sm mb-2" style="color:var(--text-2);">{ep.desc}</p>
            <p class="text-xs mb-2" style="color:var(--text-3);">
              Params: <code style="color:var(--red);">{ep.params}</code>
            </p>
            <p class="text-xs font-bold mb-1" style="color:var(--text-3);">Ví dụ:</p>
            <div class="overflow-x-auto">
              <code class="text-xs block p-2 rounded" style="background:var(--bg-surface);color:var(--red);white-space:nowrap;">
                {ep.example}
              </code>
            </div>
            <details class="mt-2">
              <summary class="text-xs cursor-pointer" style="color:var(--text-3);">Xem response mẫu</summary>
              <pre class="text-xs mt-2 p-3 rounded overflow-x-auto"
                style="background:#0f172a;color:#94a3b8;">{ep.response}</pre>
            </details>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Code examples -->
  <section class="mb-5">
    <h2 class="section-label mb-3">💻 Code examples</h2>
    <div class="card overflow-hidden">
      <div class="px-4 py-2 border-b text-xs font-bold" style="border-color:var(--border);color:var(--text-3);">JavaScript / Fetch</div>
      <pre class="text-xs p-4 overflow-x-auto" style="background:#0f172a;color:#94a3b8;">{`// Lấy thông tin ngày hôm nay
const today = new Date().toISOString().split('T')[0];
const res  = await fetch(\`${BASE}/api/v1/day?date=\${today}\`);
const data = await res.json();
console.log(data.label); // "Ngày Tốt"`}</pre>
    </div>

    <div class="card overflow-hidden mt-3">
      <div class="px-4 py-2 border-b text-xs font-bold" style="border-color:var(--border);color:var(--text-3);">cURL</div>
      <pre class="text-xs p-4 overflow-x-auto" style="background:#0f172a;color:#94a3b8;">{`curl "${BASE}/api/v1/good-days?year=2026&month=4&min_score=4"`}</pre>
    </div>

    <div class="card overflow-hidden mt-3">
      <div class="px-4 py-2 border-b text-xs font-bold" style="border-color:var(--border);color:var(--text-3);">Python</div>
      <pre class="text-xs p-4 overflow-x-auto" style="background:#0f172a;color:#94a3b8;">{`import requests
res  = requests.get("${BASE}/api/v1/month", params={"year":2026,"month":4})
days = res.json()["days"]
good = [d for d in days if d["score"] >= 4]
print(f"{len(good)} ngày tốt tháng 4/2026")`}</pre>
    </div>
  </section>

  <!-- Notes -->
  <div class="card p-4 mb-4" style="background:var(--gold-pale);border-color:rgba(241,196,15,0.4);">
    <p class="font-bold text-sm mb-1" style="color:var(--text-1);">📌 Lưu ý</p>
    <ul class="text-sm flex flex-col gap-1" style="color:var(--text-2);">
      <li>• Thuật toán lịch âm theo Hồ Ngọc Đức</li>
      <li>• Tất cả ngày tính theo timezone <strong>Asia/Ho_Chi_Minh (UTC+7)</strong></li>
      <li>• Rate limit: reasonable use (không spam)</li>
      <li>• Miễn phí cho dự án cá nhân và thương mại</li>
    </ul>
  </div>

</BaseLayout>
