---
// src/pages/van-khan/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE }   from '../../lib/constants';
import { VAN_KHAN_DATA, CATEGORY_LABEL } from '../../lib/vanKhan';

const canonical  = `${SITE.baseUrl}/van-khan`;
const title      = 'Văn Khấn — 24 bài văn khấn cúng đầy đủ chuẩn nhất'.slice(0,60);
const description = 'Tổng hợp 24 bài văn khấn chuẩn: Giao Thừa, Rằm, Giỗ Tổ, Thần Tài, Khai Trương, Vu Lan... đầy đủ nhất theo phong tục Việt Nam.'.slice(0,160);

const categories = Object.entries(CATEGORY_LABEL);
---

<BaseLayout {title} {description} canonicalUrl={canonical}>
  <div class="mb-4">
    <h1 class="font-display font-bold text-2xl mb-1" style="color:var(--text-1);">🙏 Văn Khấn</h1>
    <p class="text-sm" style="color:var(--text-3);">{VAN_KHAN_DATA.length} bài văn khấn theo phong tục Việt Nam</p>
  </div>

  <!-- Search -->
  <div class="relative mb-3">
    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-base">🔍</span>
    <input type="text" id="vk-search" placeholder="Tìm bài khấn... (Giao thừa, Thần Tài, Khai trương...)"
      class="input-base pl-9" />
  </div>

  <!-- Category filter -->
  <div class="flex gap-2 overflow-x-auto pb-2 mb-3 scrollbar-none">
    <button class="vk-cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold active-cat"
      data-cat="all" style="background:var(--gold-btn);color:white;">
      Tất cả ({VAN_KHAN_DATA.length})
    </button>
    {categories.map(([cat, label]) => {
      const count = VAN_KHAN_DATA.filter(v => v.category === cat).length;
      if (count === 0) return null;
      return (
        <button class="vk-cat-btn shrink-0 px-3 py-1.5 rounded-full text-sm font-semibold"
          data-cat={cat}
          style="background:var(--bg-elevated);color:var(--text-2);">
          {label} ({count})
        </button>
      );
    })}
  </div>

  <!-- List -->
  <div class="card" id="vk-list">
    {VAN_KHAN_DATA.map((vk, i) => (
      <a href={`/van-khan/${vk.slug}`}
        class="vk-item flex items-center gap-3 px-4 py-3.5 no-underline"
        style={`border-bottom:${i < VAN_KHAN_DATA.length-1 ? '1px solid var(--border)' : 'none'};`}
        data-cat={vk.category}
        data-name={vk.ten.toLowerCase()}>
        <span class="text-2xl shrink-0">{vk.icon}</span>
        <div class="flex-1 min-w-0">
          <p class="font-semibold text-sm" style="color:var(--text-1);">{vk.ten}</p>
          <p class="text-xs mt-0.5" style="color:var(--text-3);">{vk.dip}</p>
        </div>
        <span style="color:var(--text-4);">›</span>
      </a>
    ))}
  </div>
</BaseLayout>

<script is:inline>
(function() {
  var searchEl = document.getElementById('vk-search');
  var catBtns  = document.querySelectorAll('.vk-cat-btn');
  var items    = document.querySelectorAll('.vk-item');
  var activeCat = 'all';

  function filter() {
    var q = (searchEl?.value || '').toLowerCase();
    items.forEach(function(item) {
      var el = item;
      var name = el.dataset.name || '';
      var cat  = el.dataset.cat  || '';
      var matchCat  = activeCat === 'all' || cat === activeCat;
      var matchName = !q || name.includes(q);
      el.style.display = (matchCat && matchName) ? '' : 'none';
    });
  }

  searchEl?.addEventListener('input', filter);

  catBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      catBtns.forEach(function(b) {
        b.style.background = 'var(--bg-elevated)';
        b.style.color      = 'var(--text-2)';
      });
      btn.style.background = 'var(--gold-btn)';
      btn.style.color      = 'white';
      activeCat = btn.dataset.cat || 'all';
      filter();
    });
  });
})();
</script>
