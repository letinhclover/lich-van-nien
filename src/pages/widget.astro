---
// src/pages/widget.astro — Widget nhúng gallery
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE } from '../lib/constants';
import { todayVN } from '../lib/dateUtils';

const { day, month, year } = todayVN();
const dateStr = `${year}-${String(month).padStart(2,'0')}-${String(day).padStart(2,'0')}`;

const canonical  = `${SITE.baseUrl}/widget`;
const title      = 'Widget Lịch Âm — Nhúng vào website của bạn | Lịch Vạn Niên'.slice(0,60);
const description = 'Nhúng lịch âm vào website, blog của bạn chỉ với 2 dòng code. Widget hiển thị ngày tốt xấu, giờ hoàng đạo cập nhật hàng ngày.';
---

<BaseLayout {title} {description} canonicalUrl={canonical}>

  <Breadcrumb items={[
    { label: 'Trang chủ', href: '/' },
    { label: 'Widget nhúng' },
  ]} />

  <h1 class="font-display font-bold text-2xl mb-2" style="color:var(--text-1);">
    🔌 Widget Lịch Vạn Niên AI
  </h1>
  <p class="text-sm mb-6" style="color:var(--text-2);">
    Nhúng lịch âm vào website, blog của bạn chỉ với 2 dòng code.
    Tự động cập nhật hàng ngày.
  </p>

  <!-- Preview 3 sizes -->
  <section class="mb-6">
    <h2 class="section-label mb-3">👁 Xem trước</h2>

    <div class="flex flex-col gap-4">
      <!-- Mini -->
      <div class="card p-4">
        <p class="text-xs font-bold mb-2" style="color:var(--text-3);">Mini (200×80px)</p>
        <div
          data-lich-widget
          data-size="mini"
          data-theme="auto"
          data-date={dateStr}
          style="max-width:220px;"
        ></div>
      </div>

      <!-- Standard -->
      <div class="card p-4">
        <p class="text-xs font-bold mb-2" style="color:var(--text-3);">Standard (320×180px)</p>
        <div
          data-lich-widget
          data-size="standard"
          data-theme="auto"
          data-date={dateStr}
          style="max-width:340px;"
        ></div>
      </div>
    </div>
  </section>

  <!-- Code copy -->
  <section class="mb-6">
    <h2 class="section-label mb-3">📋 Code nhúng</h2>

    {[
      { size: 'mini', label: 'Mini' },
      { size: 'standard', label: 'Standard' },
    ].map(({ size, label }) => (
      <div class="card p-4 mb-3">
        <p class="text-xs font-bold mb-2" style="color:var(--text-3);">{label}</p>
        <pre
          class="text-xs p-3 rounded-lg overflow-x-auto"
          style="background:var(--bg-surface);color:var(--text-1);"
          id={`code-${size}`}
        >{`<div data-lich-widget data-size="${size}" data-theme="auto"></div>\n<script src="${SITE.baseUrl}/widget.js" async><\/script>`}</pre>
        <button
          class="btn-secondary text-xs mt-2 py-1.5"
          onclick={`navigator.clipboard.writeText(document.getElementById('code-${size}').textContent).then(()=>alert('Đã copy!'))`}
        >
          📋 Copy code
        </button>
      </div>
    ))}
  </section>

  <!-- Attributes -->
  <section class="mb-6">
    <h2 class="section-label mb-3">⚙️ Tuỳ chỉnh</h2>
    <div class="card overflow-hidden">
      <div class="grid grid-cols-3 border-b text-xs font-bold px-3 py-2" style="border-color:var(--border);color:var(--text-3);">
        <span>Thuộc tính</span>
        <span>Giá trị</span>
        <span>Mặc định</span>
      </div>
      {[
        ['data-size',  'mini / standard',    'standard'],
        ['data-theme', 'auto / light / dark', 'auto'],
        ['data-date',  'YYYY-MM-DD',          'Hôm nay'],
      ].map(([attr, vals, def]) => (
        <div class="grid grid-cols-3 border-b px-3 py-2.5 text-sm" style="border-color:var(--border);">
          <code style="color:var(--red);font-size:0.75rem;">{attr}</code>
          <span style="color:var(--text-2);font-size:0.75rem;">{vals}</span>
          <span style="color:var(--text-3);font-size:0.75rem;">{def}</span>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>

<!-- Load widget script for preview -->
<script src="/widget.js" async></script>
