---

<BaseLayout {title} {description} canonicalUrl={canonical}>
  <Breadcrumb items={[{ label:'Trang chủ', href:'/' }, { label:'Văn Khấn' }]} />

  <div class="mb-5">
    <h1 class="font-display font-bold text-2xl mb-1" style="color:var(--text-1);">🙏 Văn Khấn Cổ Truyền</h1>
    <p class="text-sm" style="color:var(--text-3);">{VAN_KHAN.length} bài văn khấn thông dụng nhất</p>
  </div>

  <!-- Search/filter hint -->
  <div class="flex gap-2 mb-4 overflow-x-auto pb-1" style="scrollbar-width:none;">
    {['Tất cả','Gia tiên','Thần Tài','Lễ Tết','Sự kiện'].map((tag, i) => (
      <span class="flex-shrink-0 px-3 py-1.5 rounded-full text-sm font-medium cursor-pointer"
        style={i===0 ? 'background:var(--gold);color:white;' : 'background:var(--bg-card);color:var(--text-2);border:1px solid var(--border);'}>
        {tag}
      </span>
    ))}
  </div>

  <!-- List -->
  <div class="flex flex-col gap-2">
    {VAN_KHAN.map(vk => (
      <details class="card group">
        <summary class="flex items-center gap-3 px-4 py-4 cursor-pointer list-none" style="-webkit-tap-highlight-color:transparent;">
          <span class="text-2xl shrink-0">{vk.icon}</span>
          <div class="flex-1 min-w-0">
            <p class="font-bold text-base" style="color:var(--text-1);">{vk.ten}</p>
            <p class="text-xs mt-0.5" style="color:var(--text-3);">{vk.dip} · {vk.noi}</p>
          </div>
          <span class="text-xl shrink-0" style="color:var(--text-4);">›</span>
        </summary>

        <div class="px-4 pb-4">
          <div class="rounded-xl p-4 mb-3" style="background:var(--bg-surface);">
            <p class="text-sm leading-relaxed whitespace-pre-line" style="color:var(--text-2);font-family:Georgia,serif;">{vk.noi_dung}</p>
          </div>
          <button
            class="btn-secondary w-full text-sm py-2.5"
            onclick={`navigator.clipboard.writeText(document.querySelector('#vk-${vk.id}').textContent).then(()=>alert('Đã sao chép!'))`}
            id={`vk-${vk.id}-btn`}>
            📋 Sao chép bài khấn
          </button>
          <span id={`vk-${vk.id}`} class="hidden">{vk.noi_dung}</span>
        </div>
      </details>
    ))}
  </div>

  <div class="card p-4 mt-4">
    <p class="text-xs leading-relaxed" style="color:var(--text-3);">
      ✳️ Các bài văn khấn trên mang tính tham khảo theo phong tục truyền thống Việt Nam.
      Có thể điều chỉnh cho phù hợp với hoàn cảnh gia đình.
    </p>
  </div>
</BaseLayout>
