---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE }   from '../lib/constants';

const canonical  = `${SITE.baseUrl}/van-khan`;
const title      = 'Văn Khấn Nôm — 24 Bài Văn Khấn Cổ Truyền Việt Nam'.slice(0,60);
const description = 'Tổng hợp 24 bài văn khấn cổ truyền Việt Nam: cúng gia tiên, thần tài, cúng rằm, mùng một, cúng đầu năm, cúng ông Táo, cúng cô hồn và nhiều bài khác.'.slice(0,160);

const VAN_KHAN = [
