---
import BaseLayout     from '../layouts/BaseLayout.astro';
import Breadcrumb     from '../components/Breadcrumb.astro';
import BanMenhChecker from '../components/BanMenhChecker';
import { SITE }       from '../lib/constants';

const canonical  = `${SITE.baseUrl}/ban-menh`;
const title      = 'Xem bản mệnh ngũ hành theo năm sinh — Nạp Âm 60 tuổi'.slice(0,60);
const description = 'Tra cứu bản mệnh ngũ hành theo năm sinh: Nạp Âm 60 can chi, màu hợp, hướng tốt, nghề nghiệp phù hợp theo phong tục truyền thống Việt Nam.'.slice(0,160);
---

<BaseLayout {title} {description} canonicalUrl={canonical}>

  <Breadcrumb items={[
    { label:'Trang chủ', href:'/' },
    { label:'Bản Mệnh Ngũ Hành' },
  ]} />

  <div class="text-center mb-5">
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl text-2xl mb-3"
      style="background:linear-gradient(135deg,#e67e22,#f39c12);box-shadow:0 4px 16px rgba(230,126,34,0.3);">
      🌍
    </div>
    <h1 class="font-display font-bold text-2xl mb-1" style="color:var(--text-1);">
      Xem Bản Mệnh Ngũ Hành
    </h1>
    <p class="text-sm" style="color:var(--text-3);">
      Nạp Âm 60 can chi — màu hợp, hướng tốt, nghề phù hợp
    </p>
  </div>

  <BanMenhChecker client:load />

  <div class="mt-5 card p-4">
    <h2 class="font-bold text-sm mb-2" style="color:var(--text-1);">📖 Nạp Âm Ngũ Hành là gì?</h2>
    <p class="text-sm leading-relaxed" style="color:var(--text-2);">
      Nạp Âm là hệ thống xác định ngũ hành (Kim, Mộc, Thủy, Hỏa, Thổ) của mỗi người theo
      năm sinh can chi. Khác với ngũ hành can đơn giản, Nạp Âm dùng bảng 60 can chi để
      xác định chính xác hơn — ví dụ Bính Ngọ mệnh <strong>Thiên Hà Thủy</strong> (Thủy)
      thay vì Hỏa theo can Bính.
    </p>
  </div>

</BaseLayout>
