---
// src/pages/tu-van.astro — Trang tư vấn AI
import BaseLayout  from '../layouts/BaseLayout.astro';
import AIChatbot   from '../components/AIChatbot';
import Breadcrumb  from '../components/Breadcrumb.astro';
import { SITE }    from '../lib/constants';
import { todayVN, formatDateVN } from '../lib/dateUtils';
import { getCanChi, solarToLunar } from '../lib/amlich';

const { day, month, year } = todayVN();
const lunar  = solarToLunar(day, month, year);
const canChi = getCanChi(day, month, year);
const todayDateStr = `${year}-${String(month).padStart(2,'0')}-${String(day).padStart(2,'0')}`;

const title       = 'Tư Vấn AI Lịch Vạn Niên — Hỏi Thầy Phong Thủy AI | Lịch Vạn Niên'.slice(0,60);
const description = 'Hỏi thầy AI về phong thủy, ngày tốt xấu, chọn ngày quan trọng. Luận giải theo âm lịch, can chi, ngũ hành. Miễn phí 3 câu/ngày.'.slice(0,160);
const canonical   = `${SITE.baseUrl}/tu-van`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Tư vấn AI lịch vạn niên có chính xác không?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'AI tư vấn dựa trên thuật toán lịch pháp Hồ Ngọc Đức và kiến thức phong thủy truyền thống. Thông tin mang tính tham khảo theo quan niệm dân gian Việt Nam.',
      },
    },
    {
      '@type': 'Question',
      name: 'Mỗi ngày hỏi được bao nhiêu câu?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Miễn phí 3 câu hỏi mỗi ngày. Lượt hỏi reset lúc 00:00 mỗi ngày.',
      },
    },
  ],
};
---

<BaseLayout {title} {description} canonicalUrl={canonical} {jsonLd}>

  <Breadcrumb items={[
    { label: 'Trang chủ', href: '/' },
    { label: 'Tư Vấn AI' },
  ]} />

  <!-- Hero -->
  <div class="text-center mb-5">
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl text-2xl mb-3"
      style="background:linear-gradient(135deg,var(--red),var(--red-dark));box-shadow:var(--shadow-do);">
      🤖
    </div>
    <h1 class="font-display font-bold text-2xl mb-1" style="color:var(--text-1);">
      Tư Vấn AI Phong Thủy
    </h1>
    <p class="text-sm" style="color:var(--text-3);">
      Hỏi thầy AI về lịch âm, ngày tốt xấu, can chi — miễn phí 3 câu/ngày
    </p>
  </div>

  <!-- Context hôm nay -->
  <div class="card p-3 mb-4 flex items-center gap-3" style="background:var(--red-pale);border-color:var(--border-red);">
    <span class="text-lg shrink-0">📅</span>
    <div class="text-sm" style="color:var(--text-2);">
      <span class="font-semibold">Hôm nay:</span>
      {day}/{month}/{year} · Ngày <strong>{canChi.ngay.display}</strong>
      · {lunar.day}/{lunar.month} {lunar.yearName}
    </div>
  </div>

  <!-- Chatbot React Island -->
  <div class="mb-4">
    <AIChatbot client:load />
  </div>

  <!-- Disclaimer -->
  <p class="text-xs text-center mb-4" style="color:var(--text-4);">
    ⚠️ Nội dung mang tính tham khảo theo quan niệm dân gian. Không thay thế tư vấn chuyên gia.
  </p>

  <!-- FAQ -->
  <div class="card p-4 mb-2">
    <h2 class="font-bold text-sm mb-3" style="color:var(--text-1);">❓ Câu hỏi thường gặp</h2>
    <div class="flex flex-col gap-3">
      <div>
        <p class="font-semibold text-sm" style="color:var(--text-1);">Mỗi ngày hỏi được bao nhiêu câu?</p>
        <p class="text-sm mt-1" style="color:var(--text-2);">Miễn phí 3 câu/ngày. Lượt hỏi reset lúc 00:00 mỗi ngày theo giờ Việt Nam.</p>
      </div>
      <div>
        <p class="font-semibold text-sm" style="color:var(--text-1);">AI tư vấn dựa trên gì?</p>
        <p class="text-sm mt-1" style="color:var(--text-2);">Dựa trên thuật toán lịch pháp Hồ Ngọc Đức, can chi, ngũ hành và kiến thức phong thủy truyền thống Việt Nam.</p>
      </div>
    </div>
  </div>

</BaseLayout>
