---
// src/pages/tet-2026.astro — Tết Nguyên Đán 2026 — SEO page
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE }   from '../lib/constants';
import { solarToPath } from '../lib/dateUtils';

const canonical  = `${SITE.baseUrl}/tet-2026`;
const title      = 'Tết Nguyên Đán 2026 — Mùng 1 Tết là ngày mấy dương lịch?'.slice(0,60);
const description = 'Tết Bính Ngọ 2026: Mùng 1 Tết là ngày 29/1/2026 dương lịch. Lịch nghỉ Tết 2026, can chi từng ngày, phong tục truyền thống ngày Tết Việt Nam đầy đủ.'.slice(0,160);

// Ngày Tết 2026 đã xác nhận
const TET_SOLAR = { d:29, m:1, y:2026 };
const NGHI_TET  = { from:'25/1/2026', to:'3/2/2026', total:10 };

// Can chi từng ngày Tết
const NGAY_TET = [
  { solar:'29/1', lunar:'Mùng 1',   canChi:'Nhâm Tuất', tuNghia:'Mùng 1 Tết — Ngày đầu năm, xuất hành, chúc Tết', path:solarToPath(29,1,2026) },
  { solar:'30/1', lunar:'Mùng 2',   canChi:'Quý Hợi',   tuNghia:'Mùng 2 Tết — Về nhà vợ/chồng, thăm họ hàng', path:solarToPath(30,1,2026) },
  { solar:'31/1', lunar:'Mùng 3',   canChi:'Giáp Tý',   tuNghia:'Mùng 3 Tết — Khai trương, đi làm trở lại', path:solarToPath(31,1,2026) },
  { solar:'1/2',  lunar:'Mùng 4',   canChi:'Ất Sửu',    tuNghia:'Mùng 4 Tết — Ngày bình thường đầu năm', path:solarToPath(1,2,2026) },
  { solar:'2/2',  lunar:'Mùng 5',   canChi:'Bính Dần',  tuNghia:'Mùng 5 Tết — Tết Đoan Ngọ nhỏ, cúng xua đuổi bệnh tật', path:solarToPath(2,2,2026) },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type':    'FAQPage',
  mainEntity: [
    { '@type':'Question', name:'Mùng 1 Tết 2026 là ngày mấy dương lịch?',
      acceptedAnswer:{ '@type':'Answer', text:'Mùng 1 Tết Bính Ngọ 2026 là ngày 29 tháng 1 năm 2026 dương lịch (thứ Năm).' }},
    { '@type':'Question', name:'Tết 2026 là năm con gì?',
      acceptedAnswer:{ '@type':'Answer', text:'Tết 2026 là năm Bính Ngọ — năm con Ngựa, mệnh Thiên Hà Thủy.' }},
    { '@type':'Question', name:'Nghỉ Tết 2026 từ ngày nào đến ngày nào?',
      acceptedAnswer:{ '@type':'Answer', text:'Dự kiến nghỉ Tết Bính Ngọ 2026 từ 25/1/2026 đến 3/2/2026 (10 ngày). Lịch chính thức do Chính phủ công bố.' }},
    { '@type':'Question', name:'Giao thừa Tết 2026 là đêm nào?',
      acceptedAnswer:{ '@type':'Answer', text:'Giao thừa Tết Bính Ngọ 2026 là đêm 28/1/2026 (30 tháng Chạp Ất Tỵ) sang 29/1/2026 (Mùng 1 Bính Ngọ).' }},
    { '@type':'Question', name:'Tháng Chạp 2025 có đủ 30 ngày không?',
      acceptedAnswer:{ '@type':'Answer', text:'Có. Tháng Chạp năm Ất Tỵ 2025 có đủ 30 ngày, kết thúc vào 28/1/2026 dương lịch.' }},
    { '@type':'Question', name:'Năm Bính Ngọ 2026 mệnh gì?',
      acceptedAnswer:{ '@type':'Answer', text:'Năm Bính Ngọ mệnh Thiên Hà Thủy — Nước sông Ngân. Người sinh năm 2026 thuộc mệnh Thủy, con Ngựa.' }},
  ],
};

const breadcrumbSchema = {
  '@context':'https://schema.org',
  '@type':'BreadcrumbList',
  itemListElement:[
    {position:1,'@type':'ListItem',name:'Trang chủ',item:SITE.baseUrl},
    {position:2,'@type':'ListItem',name:'Tết 2026',item:canonical},
  ],
};
---

<BaseLayout {title} {description} canonicalUrl={canonical} jsonLd={[faqSchema, breadcrumbSchema]}>

  <Breadcrumb items={[
    { label:'Trang chủ', href:'/' },
    { label:'Tết 2026' },
  ]} />

  <h1 class="font-display font-bold text-2xl mb-3" style="color:var(--text-1);">
    🧧 Tết Nguyên Đán 2026
  </h1>

  <!-- ANSWER BOX — đây là thứ Google featured snippet -->
  <div class="card p-4 mb-5" style="background:linear-gradient(135deg,rgba(192,57,43,0.08),rgba(241,196,15,0.08));border-color:rgba(192,57,43,0.3);">
    <p class="text-xs font-bold mb-1" style="color:var(--red);">📅 TẾT BÍNH NGỌ 2026</p>
    <p class="font-display font-bold text-2xl mb-1" style="color:var(--text-1);">
      Mùng 1 Tết = <span style="color:var(--red);">29 tháng 1 năm 2026</span>
    </p>
    <p class="text-sm" style="color:var(--text-2);">
      Thứ Năm · Nhâm Tuất · Năm con Ngựa (Bính Ngọ) · Mệnh Thiên Hà Thủy
    </p>
    <div class="flex gap-3 mt-3 text-sm flex-wrap">
      <span class="badge-gold">🐎 Năm Bính Ngọ</span>
      <span class="badge-green">💧 Mệnh Thiên Hà Thủy</span>
      <a href={solarToPath(TET_SOLAR.d, TET_SOLAR.m, TET_SOLAR.y)}
        class="text-xs no-underline px-3 py-1 rounded-full font-bold"
        style="background:var(--red);color:white;">
        Xem chi tiết ngày này →
      </a>
    </div>
  </div>

  <!-- Lịch nghỉ -->
  <div class="card p-4 mb-4">
    <h2 class="font-bold text-sm mb-3" style="color:var(--text-1);">📋 Lịch nghỉ Tết 2026 (dự kiến)</h2>
    <div class="flex items-center justify-between p-3 rounded-xl mb-2"
      style="background:var(--red-pale);border:1px solid rgba(192,57,43,0.2);">
      <div>
        <p class="font-bold" style="color:var(--red);">Từ {NGHI_TET.from}</p>
        <p class="text-xs" style="color:var(--text-3);">25 tháng Chạp Ất Tỵ</p>
      </div>
      <span style="color:var(--text-3);">→</span>
      <div class="text-right">
        <p class="font-bold" style="color:var(--red);">đến {NGHI_TET.to}</p>
        <p class="text-xs" style="color:var(--text-3);">Mùng 5 Tết</p>
      </div>
      <div class="text-center">
        <p class="font-bold text-2xl" style="color:var(--red);">{NGHI_TET.total}</p>
        <p class="text-xs" style="color:var(--text-3);">ngày</p>
      </div>
    </div>
    <p class="text-xs" style="color:var(--text-4);">
      * Lịch nghỉ chính thức do Chính phủ quyết định, thường công bố cuối năm trước
    </p>
  </div>

  <!-- Từng ngày Tết -->
  <div class="card overflow-hidden mb-4">
    <div class="px-4 py-3 border-b" style="border-color:var(--border);">
      <h2 class="font-bold text-sm" style="color:var(--text-1);">📅 Lịch từng ngày Tết Bính Ngọ 2026</h2>
    </div>
    {NGAY_TET.map(ng => (
      <a href={ng.path} class="flex items-center gap-3 px-4 py-3 border-b no-underline hover:brightness-95 transition-all"
        style="border-color:var(--border);">
        <div class="text-center w-12 shrink-0">
          <p class="font-bold text-base" style="color:var(--red);">{ng.solar}</p>
          <p class="text-xs" style="color:var(--text-4);">{ng.lunar}</p>
        </div>
        <div class="flex-1">
          <p class="font-semibold text-sm" style="color:var(--text-1);">{ng.canChi}</p>
          <p class="text-xs" style="color:var(--text-3);">{ng.tuNghia}</p>
        </div>
        <span style="color:var(--text-4);">›</span>
      </a>
    ))}
  </div>

  <!-- Phong tục Tết -->
  <div class="card p-4 mb-4">
    <h2 class="font-bold text-sm mb-3" style="color:var(--text-1);">🎊 Phong tục Tết Nguyên Đán</h2>
    <div class="grid grid-cols-2 gap-2">
      {[
        ['🎋','Gói bánh chưng','29 Tết - Nấu bánh chưng, bánh tét cùng gia đình'],
        ['🏠','Dọn dẹp nhà cửa','23-28 Tết - Tổng vệ sinh nhà đón năm mới'],
        ['🍊','Bày mâm ngũ quả','Cúng ông bà, trang trí bàn thờ đón Tết'],
        ['🎆','Cúng giao thừa','Đêm 30 Tết - Cúng ngoài trời tiễn năm cũ'],
        ['💰','Lì xì đầu năm','Mùng 1-3 - Người lớn lì xì trẻ em, chúc may mắn'],
        ['🏮','Đi lễ chùa','Mùng 1 - Cầu bình an, sức khỏe năm mới'],
        ['🌿','Hái lộc đầu xuân','Mùng 1 - Hái cành xanh cầu may'],
        ['📝','Khai bút đầu năm','Mùng 1 - Viết những chữ tốt lành đầu năm'],
      ].map(([icon, ten, mo_ta]) => (
        <div class="card p-2.5">
          <p class="text-base mb-0.5">{icon}</p>
          <p class="font-semibold text-xs" style="color:var(--text-1);">{ten}</p>
          <p class="text-[10px] mt-0.5" style="color:var(--text-3);">{mo_ta}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Tết các năm khác -->
  <div class="card p-4 mb-4">
    <h2 class="font-bold text-sm mb-3" style="color:var(--text-1);">📆 Tết Nguyên Đán các năm</h2>
    <div class="flex flex-col gap-2">
      {[
        {y:2025, cc:'Ất Tỵ', d:'29/1/2025', path:solarToPath(29,1,2025)},
        {y:2026, cc:'Bính Ngọ', d:'29/1/2026', path:solarToPath(29,1,2026), cur:true},
        {y:2027, cc:'Đinh Mùi', d:'17/1/2027', path:solarToPath(17,1,2027)},
        {y:2028, cc:'Mậu Thân', d:'26/1/2028', path:solarToPath(26,1,2028)},
      ].map(({y, cc, d, path, cur}) => (
        <a href={path} class="flex items-center justify-between p-2.5 rounded-xl no-underline"
          style={cur ? 'background:var(--red-pale);border:1px solid rgba(192,57,43,0.3);' : 'background:var(--bg-surface);'}>
          <div>
            <span class="font-bold text-sm" style={cur ? 'color:var(--red);' : 'color:var(--text-1);'}>
              Tết {y} {cur ? '← năm nay' : ''}
            </span>
            <span class="text-xs ml-2" style="color:var(--text-3);">Năm {cc}</span>
          </div>
          <span class="text-sm font-semibold" style="color:var(--text-2);">{d}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- FAQ (hiển thị cho user) -->
  <div class="card p-4">
    <h2 class="font-bold text-sm mb-3" style="color:var(--text-1);">❓ Câu hỏi thường gặp về Tết 2026</h2>
    <div class="flex flex-col gap-3">
      {[
        ['Mùng 1 Tết 2026 là ngày mấy?', 'Mùng 1 Tết Bính Ngọ 2026 là ngày 29/1/2026 dương lịch, thứ Năm.'],
        ['Tết 2026 là năm con gì?', 'Tết 2026 là năm Bính Ngọ — năm con Ngựa, mệnh Thiên Hà Thủy.'],
        ['Giao thừa 2026 là đêm nào?', 'Đêm giao thừa là đêm 28/1/2026 sang 29/1/2026 (30 Tết sang Mùng 1).'],
        ['Nghỉ Tết 2026 mấy ngày?', 'Dự kiến 10 ngày, từ 25/1 đến 3/2/2026. Chính thức do Chính phủ công bố.'],
      ].map(([q, a]) => (
        <div>
          <p class="font-semibold text-sm mb-1" style="color:var(--text-1);">🔸 {q}</p>
          <p class="text-sm" style="color:var(--text-2);">{a}</p>
        </div>
      ))}
    </div>
  </div>

</BaseLayout>
