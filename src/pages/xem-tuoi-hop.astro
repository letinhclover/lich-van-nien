---
import BaseLayout     from '../layouts/BaseLayout.astro';
import Breadcrumb     from '../components/Breadcrumb.astro';
import TuoiHopChecker from '../components/TuoiHopChecker';
import { SITE }       from '../lib/constants';

const canonical  = `${SITE.baseUrl}/xem-tuoi-hop`;
const title      = 'Xem tuổi vợ chồng hợp không — Tra tuổi hôn nhân 2026'.slice(0,60);
const description = 'Xem tuổi vợ chồng có hợp không theo lịch âm. Nhập năm sinh cô dâu và chú rể để kiểm tra tam hợp, lục hợp, lục xung theo phong tục Việt Nam.'.slice(0,160);
---

<BaseLayout {title} {description} canonicalUrl={canonical}>

  <Breadcrumb items={[
    { label:'Trang chủ', href:'/' },
    { label:'Xem tuổi vợ chồng' },
  ]} />

  <div class="text-center mb-5">
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl text-2xl mb-3"
      style="background:linear-gradient(135deg,#c0392b,#e74c3c);box-shadow:0 4px 16px rgba(192,57,43,0.3);">
      💑
    </div>
    <h1 class="font-display font-bold text-2xl mb-1" style="color:var(--text-1);">
      Xem Tuổi Vợ Chồng Hợp Không
    </h1>
    <p class="text-sm" style="color:var(--text-3);">
      Tra cứu tam hợp, lục hợp, lục xung theo phong tục truyền thống
    </p>
  </div>

  <TuoiHopChecker client:load />

  <!-- SEO content -->
  <div class="mt-6 card p-4">
    <h2 class="font-bold text-sm mb-2" style="color:var(--text-1);">📖 Các mức độ hợp tuổi</h2>
    <div class="flex flex-col gap-2 text-sm" style="color:var(--text-2);">
      <p>• <strong>Tam Hợp (5/5):</strong> 3 tuổi cùng bộ — hợp nhất, vạn sự thuận lợi</p>
      <p>• <strong>Lục Hợp (4/5):</strong> 2 tuổi hợp đôi — duyên phận bền chặt</p>
      <p>• <strong>Bình thường (3/5):</strong> Không xung không hợp — phụ thuộc tình cảm</p>
      <p>• <strong>Lục Hại (2/5):</strong> Có trở ngại — cần nhường nhịn</p>
      <p>• <strong>Lục Xung (1/5):</strong> Khắc khí — cần hóa giải, chọn ngày tốt</p>
    </div>
  </div>

</BaseLayout>
